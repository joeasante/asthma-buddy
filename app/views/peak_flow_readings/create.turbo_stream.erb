<%# Toast notification — the index is a separate page so we just confirm and let
    the user navigate back to see their new reading in the grouped list. %>
<%= turbo_stream.replace "flash-messages" do %>
  <div id="flash-messages"
       data-controller="toast"
       data-toast-message="<%= zone_flash_message_text(@peak_flow_reading) %>"
       data-toast-variant="success">
  </div>
<% end %>
