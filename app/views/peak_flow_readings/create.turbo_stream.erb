<%# Reset the form with a fresh record and updated personal-best state %>
<%= turbo_stream.replace "peak_flow_reading_form" do %>
  <%= render "form",
        peak_flow_reading: Current.user.peak_flow_readings.new(
          recorded_at: Time.current.change(sec: 0)
        ),
        has_personal_best: @has_personal_best %>
<% end %>

<%# Show zone flash message in the layout flash area %>
<%# The layout <main id="main-content"> is the skip-link target — prepend flash notice there %>
<%= turbo_stream.prepend "main-content" do %>
  <p role="status" class="flash flash--notice"><%= @flash_message %></p>
<% end %>
