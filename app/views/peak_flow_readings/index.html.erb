<% content_for :title, "Peak Flow — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Your peak flow history — readings over time with trend charts to track your asthma control."><% end %>

<%# Amber warning banner — shown only when no personal best is set %>
<% unless @current_personal_best %>
  <div class="flash flash--warning" role="note" aria-label="Action required">
    <strong>Zone classification is off</strong> — set your personal best on your
    <%= link_to "Profile page", profile_path %> to see Green / Yellow / Red zones.
    <%= link_to "Set personal best →", profile_path, class: "pf-banner-link" %>
  </div>
<% end %>

<%= render "page_header", last_reading: @header_last_reading, month_count: @header_month_count %>

<%# Personal best hero card — shown only when PB is set %>
<% if @current_personal_best %>
  <% pb = @current_personal_best.value %>
  <div class="pf-pb-hero">
    <div class="pf-pb-hero-left">
      <p class="pf-pb-hero-label">Personal Best</p>
      <div class="pf-pb-hero-reading">
        <strong class="pf-pb-hero-value"><%= pb %></strong>
        <span class="pf-pb-hero-unit">L/min</span>
      </div>
      <p class="pf-pb-hero-sub">Set <%= @current_personal_best.recorded_at.strftime("%-d %b %Y") %></p>
    </div>
    <div class="pf-pb-hero-zones">
      <div class="pf-pb-zone-row">
        <span class="pf-pb-zone-dot pf-pb-zone-dot--green"></span>
        <span><strong>Green</strong> &mdash; &ge;&nbsp;<%= (pb * 0.8).round %> L/min</span>
      </div>
      <div class="pf-pb-zone-row">
        <span class="pf-pb-zone-dot pf-pb-zone-dot--yellow"></span>
        <span><strong>Yellow</strong> &mdash; <%= (pb * 0.5).round %>&ndash;<%= (pb * 0.8).round - 1 %> L/min</span>
      </div>
      <div class="pf-pb-zone-row">
        <span class="pf-pb-zone-dot pf-pb-zone-dot--red"></span>
        <span><strong>Red</strong> &mdash; &lt;&nbsp;<%= (pb * 0.5).round %> L/min</span>
      </div>
    </div>
    <div class="pf-pb-hero-action">
      <%= link_to "Update personal best", profile_path, class: "pf-pb-hero-link" %>
    </div>
  </div>
<% end %>

<% if @current_personal_best && @current_personal_best.recorded_at < PersonalBestRecord::STALE_THRESHOLD.ago %>
  <% months_ago = ((Date.current - @current_personal_best.recorded_at.to_date) / 30).round %>
  <div class="pf-pb-age-notice" role="note">
    Your personal best was set <%= months_ago %> months ago.
    If your lung function has changed, <%= link_to "updating it", profile_path %> will keep your zone readings accurate.
  </div>
<% end %>

<%# Everything below lives inside the Turbo Frame so filters, stats, and chart
    all update together on every filter/page change. %>
<section id="peak-flow-graph" aria-label="Peak flow reading history" data-controller="hash-scroll">
  <%= turbo_frame_tag "readings_content" do %>

    <%# 1. Chart — visible immediately on page load %>
    <% if @chart_data&.any? %>
      <div class="chart-section chart-section--peakflow"
           data-controller="chart"
           data-chart-type-value="peakflow-bands"
           data-chart-personal-best-value="<%= @current_personal_best&.value || 0 %>"
           data-chart-data-value="<%= @chart_data.to_json %>"
           data-chart-health-events-value="<%= @health_event_markers.to_json %>">
        <div class="chart-session-toggle" role="group" aria-label="Toggle session">
          <button type="button"
                  class="chart-session-btn chart-session-btn--morning"
                  data-chart-target="sessionBtn"
                  data-chart-series-param="morning"
                  data-action="click->chart#toggleSeries"
                  aria-pressed="true">
            <span class="chart-session-btn-dot" aria-hidden="true"></span>
            Morning
          </button>
          <button type="button"
                  class="chart-session-btn chart-session-btn--evening"
                  data-chart-target="sessionBtn"
                  data-chart-series-param="evening"
                  data-action="click->chart#toggleSeries"
                  aria-pressed="true">
            <span class="chart-session-btn-dot" aria-hidden="true"></span>
            Evening
          </button>
        </div>
        <div class="chart-canvas-wrapper">
          <canvas class="chart-canvas chart-canvas--peakflow"
                  aria-label="Peak flow readings chart"
                  role="img">
          </canvas>
        </div>
      </div>
      <% if @health_event_markers&.any? { |m| m["type"] == "illness" } %>
        <div class="pf-illness-legend">
          <span class="pf-illness-legend-swatch" aria-hidden="true"></span>
          Illness period
        </div>
      <% end %>
    <% end %>

    <%# 2. Filters %>
    <%= render "filter_bar",
          active_preset: @active_preset,
          start_date: @start_date,
          end_date: @end_date,
          active_zone: @active_zone %>

    <%# 3. Period stats — compact strip summarising the filtered window %>
    <div class="pf-stat-strip" aria-label="Period summary">
      <% if @period_count.to_i > 0 %>
        <span class="pf-stat-strip-item">
          <strong><%= @period_count %></strong> <%= "reading".pluralize(@period_count) %>
        </span>
        <% if @period_avg %>
          <span class="pf-stat-strip-sep" aria-hidden="true">&middot;</span>
          <span class="pf-stat-strip-item">
            avg <strong><%= @period_avg %></strong> L/min<% if @period_avg_pct %> <span class="pf-stat-strip-sub">(<%= @period_avg_pct %>%)</span><% end %>
          </span>
        <% end %>
        <% if @period_best %>
          <span class="pf-stat-strip-sep" aria-hidden="true">&middot;</span>
          <span class="pf-stat-strip-item">
            best <strong><%= @period_best %></strong> L/min<% if @period_best_pct %> <span class="pf-stat-strip-sub">(<%= @period_best_pct %>%)</span><% end %>
          </span>
        <% end %>
      <% else %>
        <span class="pf-stat-strip-item pf-stat-strip-item--empty">No readings in this period</span>
      <% end %>
    </div>

    <%# 4. Reading list or empty state %>
    <% if @peak_flow_readings.empty? %>
      <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M24 6C18.5 6 14 10.5 14 16C14 19.2 15.5 22 17.8 23.8C16.7 25.6 16 27.7 16 30C16 36.6 20.5 42 24 42C27.5 42 32 36.6 32 30C32 27.7 31.3 25.6 30.2 23.8C32.5 22 34 19.2 34 16C34 10.5 29.5 6 24 6Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M24 16V24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M20 20C20 20 21.5 22 24 22C26.5 22 28 20 28 20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <% if @active_zone || @active_preset == "custom" || @start_date || @end_date %>
          <p class="empty-state-heading">No readings match this filter</p>
          <p class="empty-state-body">Try clearing the zone or date filter to see all your readings.</p>
          <%= link_to "Clear filters", peak_flow_readings_path, class: "btn-primary", data: { turbo_frame: "readings_content" } %>
        <% else %>
          <p class="empty-state-heading">No readings yet</p>
          <p class="empty-state-body">Record your peak flow each morning to track trends over time.</p>
          <%= link_to "Record a reading", new_peak_flow_reading_path, class: "btn-primary" %>
        <% end %>
      </div>
    <% else %>
      <%# Skeleton — shown by CSS while turbo-frame[busy], mimics card shape %>
      <div class="pf-skeleton-block" aria-hidden="true">
        <% 3.times do %>
          <div class="pf-skeleton-day-group">
            <div class="skeleton pf-skeleton-date-label"></div>
            <div class="skeleton pf-skeleton-card"></div>
            <div class="skeleton pf-skeleton-card pf-skeleton-card--short"></div>
          </div>
        <% end %>
      </div>

      <%# Grouped-by-date card list %>
      <div class="pf-day-list">
        <% @grouped_readings.each do |date, readings| %>
          <div class="pf-day-group">
            <time class="pf-day-date" datetime="<%= date.iso8601 %>">
              <% if date == Date.current %>
                Today &middot; <%= date.strftime("%-d %b %Y") %>
              <% elsif date == Date.yesterday %>
                Yesterday &middot; <%= date.strftime("%-d %b %Y") %>
              <% else %>
                <%= date.strftime("%A, %-d %B %Y") %>
              <% end %>
            </time>
            <div class="pf-day-readings">
              <% readings.sort_by { |r| r.time_of_day == "morning" ? 0 : 1 }.each do |reading| %>
                <%= render "reading_card", reading: reading %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%= render "pagination",
            current_page: @current_page,
            total_pages: @total_pages,
            active_preset: @active_preset,
            start_date: @start_date,
            end_date: @end_date,
            active_zone: @active_zone %>
    <% end %>

  <% end %>
</section>
