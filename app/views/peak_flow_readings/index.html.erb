<% content_for :title, "Peak Flow" %>

<%# Amber warning banner — shown only when no personal best is set %>
<% unless @current_personal_best %>
  <div class="flash flash--warning" role="note" aria-label="Action required">
    <strong>Zone classification is off</strong> — set your personal best on your
    <%= link_to "Profile page", profile_path %> to see Green / Yellow / Red zones.
    <%= link_to "Set personal best →", profile_path, class: "pf-banner-link" %>
  </div>
<% end %>

<div class="page-header">
  <div class="page-header-eyebrow">
    <% if @header_last_reading %>
      <span class="eyebrow-stat">Last: <strong><%= @header_last_reading.value %> L/min</strong></span>
      <% if @header_last_reading.zone %>
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span class="eyebrow-pill eyebrow-pill--<%= @header_last_reading.zone_css_modifier %>">
          <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor" aria-hidden="true"><circle cx="3" cy="3" r="3"/></svg>
          <%= @header_last_reading.zone.capitalize %> zone
        </span>
      <% end %>
      <span class="eyebrow-dot" aria-hidden="true"></span>
    <% end %>
    <span class="eyebrow-stat"><strong><%= @header_month_count %></strong> <%= "reading".pluralize(@header_month_count) %> this month</span>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
      </div>
      <div>
        <h1>Peak Flow</h1>
        <p class="page-header-subtitle">Your breathing measurements over time</p>
      </div>
    </div>
    <div class="page-header-actions">
      <%= link_to "+ Record reading", new_peak_flow_reading_path, class: "btn-primary" %>
    </div>
  </div>
</div>

<%# Personal best hero card — shown only when PB is set %>
<% if @current_personal_best %>
  <% pb = @current_personal_best.value %>
  <div class="pf-pb-hero">
    <div class="pf-pb-hero-left">
      <p class="pf-pb-hero-label">Personal Best</p>
      <div class="pf-pb-hero-reading">
        <strong class="pf-pb-hero-value"><%= pb %></strong>
        <span class="pf-pb-hero-unit">L/min</span>
      </div>
      <p class="pf-pb-hero-sub">Set <%= @current_personal_best.recorded_at.strftime("%-d %b %Y") %></p>
    </div>
    <div class="pf-pb-hero-zones">
      <div class="pf-pb-zone-row">
        <span class="pf-pb-zone-dot pf-pb-zone-dot--green"></span>
        <span><strong>Green</strong> &mdash; &ge;&nbsp;<%= (pb * 0.8).round %> L/min</span>
      </div>
      <div class="pf-pb-zone-row">
        <span class="pf-pb-zone-dot pf-pb-zone-dot--yellow"></span>
        <span><strong>Yellow</strong> &mdash; <%= (pb * 0.5).round %>&ndash;<%= (pb * 0.8).round - 1 %> L/min</span>
      </div>
      <div class="pf-pb-zone-row">
        <span class="pf-pb-zone-dot pf-pb-zone-dot--red"></span>
        <span><strong>Red</strong> &mdash; &lt;&nbsp;<%= (pb * 0.5).round %> L/min</span>
      </div>
    </div>
    <div class="pf-pb-hero-action">
      <%= link_to "Update personal best", profile_path, class: "pf-pb-hero-link" %>
    </div>
  </div>
<% end %>

<%# Period summary stats %>
<div class="dash-stats" style="margin-bottom: 1.25rem;">
  <div class="dash-stat">
    <span class="dash-stat-label">Readings</span>
    <% if @period_count.to_i > 0 %>
      <span class="dash-stat-value"><%= @period_count %></span>
      <span class="dash-stat-sub">in this period</span>
    <% else %>
      <span class="dash-stat-value dash-stat-value--empty">&mdash;</span>
      <span class="dash-stat-sub">No readings</span>
    <% end %>
  </div>
  <div class="dash-stat">
    <span class="dash-stat-label">Average</span>
    <% if @period_avg %>
      <span class="dash-stat-value"><%= @period_avg %><span class="dash-stat-unit"> L/min</span></span>
      <% if @current_personal_best %>
        <span class="dash-stat-sub"><%= ((@period_avg.to_f / @current_personal_best.value) * 100).round %>% of personal best</span>
      <% end %>
    <% else %>
      <span class="dash-stat-value dash-stat-value--empty">&mdash;</span>
      <span class="dash-stat-sub">No data</span>
    <% end %>
  </div>
  <div class="dash-stat">
    <span class="dash-stat-label">Best this period</span>
    <% if @period_best %>
      <span class="dash-stat-value"><%= @period_best %><span class="dash-stat-unit"> L/min</span></span>
      <% if @current_personal_best %>
        <span class="dash-stat-sub"><%= ((@period_best.to_f / @current_personal_best.value) * 100).round %>% of personal best</span>
      <% end %>
    <% else %>
      <span class="dash-stat-value dash-stat-value--empty">&mdash;</span>
      <span class="dash-stat-sub">No data</span>
    <% end %>
  </div>
</div>

<%# Readings history — wrapped in Turbo Frame for filter navigation %>
<section aria-label="Peak flow reading history">
  <%= turbo_frame_tag "readings_content" do %>
    <% if @chart_data&.any? %>
      <div class="dash-section-header">
        <h2>Peak Flow history</h2>
      </div>
      <div class="chart-section"
           style="margin-bottom: 1rem;"
           data-controller="chart"
           data-chart-type-value="peakflow-zones"
           data-chart-data-value="<%= @chart_data.to_json %>">
        <div class="chart-session-toggle" role="group" aria-label="Toggle session">
          <button type="button"
                  class="chart-session-btn chart-session-btn--morning"
                  data-chart-target="sessionBtn"
                  data-chart-series-param="morning"
                  data-action="click->chart#toggleSeries"
                  aria-pressed="true">
            <span class="chart-session-btn-dot" aria-hidden="true"></span>
            Morning
          </button>
          <button type="button"
                  class="chart-session-btn chart-session-btn--evening"
                  data-chart-target="sessionBtn"
                  data-chart-series-param="evening"
                  data-action="click->chart#toggleSeries"
                  aria-pressed="true">
            <span class="chart-session-btn-dot" aria-hidden="true"></span>
            Evening
          </button>
        </div>
        <canvas class="chart-canvas"
                aria-label="Peak flow readings chart"
                role="img">
        </canvas>
      </div>
    <% end %>

    <%= render "filter_bar",
          active_preset: @active_preset,
          start_date: @start_date,
          end_date: @end_date,
          active_zone: @active_zone %>

    <% if @peak_flow_readings.empty? %>
      <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M24 6C18.5 6 14 10.5 14 16C14 19.2 15.5 22 17.8 23.8C16.7 25.6 16 27.7 16 30C16 36.6 20.5 42 24 42C27.5 42 32 36.6 32 30C32 27.7 31.3 25.6 30.2 23.8C32.5 22 34 19.2 34 16C34 10.5 29.5 6 24 6Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M24 16V24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M20 20C20 20 21.5 22 24 22C26.5 22 28 20 28 20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <% if @active_zone || @active_preset || @start_date || @end_date %>
          <p class="empty-state-heading">No readings match this filter</p>
          <p class="empty-state-body">Try clearing the zone or date filter to see all your readings.</p>
          <%= link_to "Clear filters", peak_flow_readings_path, class: "btn-primary" %>
        <% else %>
          <p class="empty-state-heading">No readings yet</p>
          <p class="empty-state-body">Record your peak flow each morning to track trends over time.</p>
          <%= link_to "Record a reading", new_peak_flow_reading_path, class: "btn-primary" %>
        <% end %>
      </div>
    <% else %>
      <%# Skeleton rows — visible only when turbo-frame is loading (CSS-driven) %>
      <div class="pf-skeleton-block" aria-hidden="true">
        <% 3.times do %>
          <div class="pf-skeleton-row">
            <div class="skeleton pf-skeleton-cell pf-skeleton-cell--date"></div>
            <div class="skeleton pf-skeleton-cell pf-skeleton-cell--value"></div>
            <div class="skeleton pf-skeleton-cell pf-skeleton-cell--badge"></div>
            <div class="skeleton pf-skeleton-cell pf-skeleton-cell--actions"></div>
          </div>
        <% end %>
      </div>

      <div class="table-wrap">
        <table class="data-table pf-readings-table" aria-label="Peak flow readings">
          <thead>
            <tr>
              <th scope="col">Date &amp; Time</th>
              <th scope="col">Reading</th>
              <th scope="col">Zone</th>
              <th scope="col"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody id="readings_tbody">
            <% @peak_flow_readings.each do |reading| %>
              <%= render "reading_row", reading: reading %>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# Zone legend %>
      <div class="pf-zone-legend" aria-label="Zone key">
        <span class="pf-zone-legend-item">
          <span class="pf-zone-legend-dot pf-zone-legend-dot--green" aria-hidden="true"></span>
          Green zone (&ge;80% of personal best)
        </span>
        <span class="pf-zone-legend-item">
          <span class="pf-zone-legend-dot pf-zone-legend-dot--yellow" aria-hidden="true"></span>
          Yellow zone (50–79%)
        </span>
        <span class="pf-zone-legend-item">
          <span class="pf-zone-legend-dot pf-zone-legend-dot--red" aria-hidden="true"></span>
          Red zone (&lt;50%)
        </span>
      </div>

      <%= render "pagination",
            current_page: @current_page,
            total_pages: @total_pages,
            active_preset: @active_preset,
            start_date: @start_date,
            end_date: @end_date,
            active_zone: @active_zone %>
    <% end %>
  <% end %>
</section>
