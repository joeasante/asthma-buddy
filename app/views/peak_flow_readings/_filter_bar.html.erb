<div class="filter-bar" role="search" aria-label="Filter peak flow history">
  <%# Period presets %>
  <div class="filter-section">
    <span class="filter-section-label">Period</span>
    <div class="filter-presets">
      <% [["7", "7 days"], ["30", "30 days"], ["90", "90 days"], ["all", "All time"]].each do |value, label| %>
        <%= link_to label,
              peak_flow_readings_path(preset: value, zone: active_zone),
              class: "filter-chip #{"filter-chip--active" if active_preset == value}",
              aria: { pressed: (active_preset == value).to_s },
              data: { turbo_frame: "readings_content" } %>
      <% end %>
    </div>
  </div>

  <%# Zone chips %>
  <div class="filter-section">
    <span class="filter-section-label">Zone</span>
    <div class="filter-presets">
      <%= link_to "All zones",
            peak_flow_readings_path(preset: active_preset, start_date: start_date, end_date: end_date),
            class: "filter-chip #{"filter-chip--active" unless active_zone}",
            aria: { pressed: active_zone.nil?.to_s },
            data: { turbo_frame: "readings_content" } %>
      <% [["green", "Green"], ["yellow", "Yellow"], ["red", "Red"]].each do |value, label| %>
        <%= link_to label,
              peak_flow_readings_path(preset: active_preset, start_date: start_date, end_date: end_date, zone: value),
              class: "filter-chip filter-chip--zone-#{value} #{"filter-chip--active" if active_zone == value}",
              aria: { pressed: (active_zone == value).to_s },
              data: { turbo_frame: "readings_content" } %>
      <% end %>
    </div>
  </div>

  <%# Custom date range %>
  <%= form_with url: peak_flow_readings_path, method: :get,
        data: { turbo_frame: "readings_content" },
        class: "filter-custom-dates" do |f| %>
    <input type="hidden" name="preset" value="custom">
    <input type="hidden" name="zone" value="<%= active_zone %>">
    <div class="filter-date-inputs">
      <%= f.label :start_date, "From" %>
      <%= f.date_field :start_date, value: start_date, class: "date-input",
            aria: { label: "Filter start date" } %>
      <%= f.label :end_date, "To" %>
      <%= f.date_field :end_date, value: end_date, class: "date-input",
            aria: { label: "Filter end date" } %>
      <%= f.submit "Apply", class: "btn-apply-dates" %>
    </div>
  <% end %>
</div>
