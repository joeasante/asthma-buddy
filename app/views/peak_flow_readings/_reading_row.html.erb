<tr id="<%= dom_id(reading) %>" class="pf-table-row">
  <td class="pf-td-datetime">
    <time datetime="<%= reading.recorded_at.iso8601 %>">
      <span class="pf-td-date"><%= reading.recorded_at.strftime("%-d %b %Y") %></span>
      <span class="pf-td-time"><%= reading.recorded_at.strftime("%H:%M") %></span>
    </time>
  </td>
  <td class="pf-td-value">
    <span class="pf-row-value"><%= reading.value %></span>
    <span class="pf-row-unit" aria-hidden="true">L/min</span>
  </td>
  <td class="pf-td-zone">
    <% zone_label = reading.zone&.capitalize || "—" %>
    <span class="zone-badge zone-badge--<%= reading.zone_css_modifier %>"
          aria-label="Zone: <%= zone_label %>">
      <%= zone_label %>
    </span>
  </td>
  <td class="pf-td-actions">
    <%= link_to "Edit",
          edit_peak_flow_reading_path(reading),
          class: "btn-edit",
          aria: { label: "Edit reading of #{reading.value} L/min on #{reading.recorded_at.strftime('%-d %b %Y')}" } %>
    <%= button_to "Delete",
          peak_flow_reading_path(reading),
          method: :delete,
          class: "btn-delete",
          aria: { label: "Delete reading of #{reading.value} L/min" },
          form: { data: { turbo: true, turbo_confirm: "Delete this reading of #{reading.value} L/min? This can't be undone." } } %>
  </td>
</tr>
