<% content_for :title, "Peak Flow Reading — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Details of a peak flow reading — value, date, and percentage of your personal best."><% end %>

<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Peak Flow", peak_flow_readings_path, class: "breadcrumb-link" %>
  <span class="breadcrumb-sep" aria-hidden="true">›</span>
  <span class="breadcrumb-current">Reading</span>
</nav>

<div class="page-header">
  <div class="page-header-main">
    <div class="page-header-left">
      <h1>Peak Flow Reading</h1>
    </div>
    <div class="page-header-actions">
      <%= link_to "Edit", edit_peak_flow_reading_path(@peak_flow_reading), class: "btn-secondary" %>
      <%= button_to "Delete", peak_flow_reading_path(@peak_flow_reading),
            method: :delete,
            class: "btn-delete",
            form: { data: { turbo: false, turbo_confirm: "Delete this reading? This cannot be undone." } } %>
    </div>
  </div>
</div>

<div class="section-card">
  <div style="padding: var(--space-lg);">
    <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: var(--space-md);">
      <span class="pf-row-value" style="font-size: 3rem; font-weight: 800; font-family: var(--font-heading);">
        <%= @peak_flow_reading.value %>
      </span>
      <span class="pf-row-unit" style="font-size: 1.125rem;">L/min</span>
      <% if @peak_flow_reading.time_of_day.present? %>
        <span class="tod-badge tod-badge--<%= @peak_flow_reading.time_of_day %>">
          <%= @peak_flow_reading.time_of_day_label %>
        </span>
      <% end %>
    </div>

    <% zone = @peak_flow_reading.zone %>
    <% if zone && @personal_best %>
      <div style="margin-bottom: var(--space-md);">
        <span class="zone-badge zone-badge--<%= zone %>">
          <%= zone.capitalize %> zone &bull; <%= @zone_percentage %>% of personal best
        </span>
      </div>
    <% end %>

    <dl style="display: flex; flex-direction: column; gap: var(--space-sm); margin-top: var(--space-md);">
      <div style="display: flex; gap: var(--space-md);">
        <dt style="color: var(--text-3); font-size: 0.9375rem; min-width: 6rem;">Date</dt>
        <dd style="color: var(--text); font-weight: 500;">
          <time datetime="<%= @peak_flow_reading.recorded_at.iso8601 %>">
            <%= @peak_flow_reading.recorded_at.strftime("%-d %B %Y") %>
          </time>
        </dd>
      </div>
      <div style="display: flex; gap: var(--space-md);">
        <dt style="color: var(--text-3); font-size: 0.9375rem; min-width: 6rem;">Time</dt>
        <dd style="color: var(--text); font-weight: 500;">
          <time datetime="<%= @peak_flow_reading.recorded_at.iso8601 %>">
            <%= @peak_flow_reading.recorded_at.strftime("%H:%M") %>
          </time>
        </dd>
      </div>
      <% if zone %>
        <div style="display: flex; gap: var(--space-md);">
          <dt style="color: var(--text-3); font-size: 0.9375rem; min-width: 6rem;">Zone</dt>
          <dd>
            <span class="zone-badge zone-badge--<%= zone %>"><%= zone.capitalize %></span>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>
