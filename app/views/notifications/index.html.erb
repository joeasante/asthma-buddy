<% content_for :title, "Notifications — Asthma Buddy" %>

<%= render "page_header", unread_count: @unread_count, last_notification: @last_notification %>

<% if @notifications.empty? %>
  <div class="empty-state">
    <svg class="empty-state-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <p class="empty-state-headline">You're all caught up.</p>
    <p class="empty-state-description">No notifications at the moment.</p>
  </div>
<% else %>
  <div class="section-card notifications-list" id="notifications-list">
    <% @notifications.each do |notification| %>
      <%= render "notification", notification: notification %>
    <% end %>
  </div>

  <% if @unread_count.zero? %>
    <div class="empty-state">
      <svg class="empty-state-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
      <p class="empty-state-headline">You're all caught up.</p>
      <p class="empty-state-description">No notifications at the moment.</p>
    </div>
  <% end %>
<% end %>
