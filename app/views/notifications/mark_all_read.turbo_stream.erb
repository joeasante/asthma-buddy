<%# Replace each previously-unread notification row %>
<% @notifications.each do |notification| %>
  <%= turbo_stream.replace dom_id(notification) do %>
    <%= render "notification", notification: notification %>
  <% end %>
<% end %>

<%# Update the page header eyebrow and hide the Mark all read button %>
<%= turbo_stream.replace "notifications-page-header" do %>
  <%= render "page_header", unread_count: 0, last_notification: @last_notification %>
<% end %>

<%# Update the nav bell badge to zero (removes badge) %>
<%= turbo_stream.replace "nav-bell" do %>
  <%= render "layouts/nav_bell", unread_count: 0 %>
<% end %>

<%# Toast feedback %>
<%= turbo_stream.replace "flash-messages" do %>
  <div id="flash-messages" data-controller="toast" data-toast-message="All notifications marked as read." data-toast-variant="success"></div>
<% end %>
