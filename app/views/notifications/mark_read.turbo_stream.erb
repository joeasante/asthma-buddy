<%# Replace the single notification row with the updated (read) version %>
<%= turbo_stream.replace dom_id(@notification) do %>
  <%= render "notification", notification: @notification %>
<% end %>

<%# Update the page header eyebrow count and Mark all read button %>
<%= turbo_stream.replace "notifications-page-header" do %>
  <%= render "page_header", unread_count: @unread_count, last_notification: @last_notification %>
<% end %>

<%# Update the nav bell badge count %>
<%= turbo_stream.replace "nav-bell" do %>
  <%= render "layouts/nav_bell", unread_count: @unread_count %>
<% end %>

<%# Toast feedback %>
<%= turbo_stream.replace "flash-messages" do %>
  <div id="flash-messages" data-controller="toast" data-toast-message="Notification marked as read." data-toast-variant="success"></div>
<% end %>
