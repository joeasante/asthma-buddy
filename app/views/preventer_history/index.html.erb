<% content_for :title, "Preventer History — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Preventer inhaler history — a day-by-day record of your preventer doses taken over the last 7 and 30 days."><% end %>

<div class="page-header">
  <div class="page-header-eyebrow">
    <span class="eyebrow-stat">Doses taken: <strong><%= @header_days_taken %> of <%= @header_days_elapsed %></strong> days this month</span>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <div>
        <h1>Preventer History</h1>
        <p class="page-header-subtitle">Your dose history for preventer inhalers</p>
      </div>
    </div>
  </div>
</div>

<turbo-frame id="adherence-grid">
  <%# Toggle lives inside the frame so it re-renders with the correct active state on every navigation %>
  <div class="adherence-toggle" role="group" aria-label="Select date range">
    <%= link_to "7 days", preventer_history_path(period: 7),
          data: { turbo_frame: "adherence-grid", turbo_action: "advance" },
          class: "btn-secondary btn-sm #{"btn-sm--active" if @period == 7}",
          aria: { current: @period == 7 ? "true" : nil } %>
    <%= link_to "30 days", preventer_history_path(period: 30),
          data: { turbo_frame: "adherence-grid", turbo_action: "advance" },
          class: "btn-secondary btn-sm #{"btn-sm--active" if @period == 30}",
          aria: { current: @period == 30 ? "true" : nil } %>
  </div>
  <% if @adherence_history.any? %>
    <% @adherence_history.each do |entry| %>
      <%= render "preventer_history/history_grid",
            medication:    entry[:medication],
            days_data:     entry[:days_data],
            period:        @period,
            grid_offset:   @grid_offset,
            padding_dates: @padding_dates %>
    <% end %>
  <% else %>
    <div class="section-card">
      <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8"  y1="2" x2="8"  y2="6"/>
            <line x1="3"  y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <h3>No preventer medications</h3>
        <p>Add a preventer inhaler in Medications to start tracking your doses here.</p>
        <%# Fix #11: label names the specific action so users know what they're adding %>
        <div class="empty-state-actions">
          <%= link_to "Add preventer inhaler", settings_medications_path, class: "btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</turbo-frame>

<p class="page-back-link">
  <%= link_to "← Back to Medications", settings_medications_path(anchor: "medications-page-header") %>
</p>
