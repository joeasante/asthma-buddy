<%= form_with model: user, url: profile_path, method: :patch do |form| %>
  <input type="hidden" name="_profile_section" value="details">

  <% detail_errors = user.errors.reject { |e| %w[password password_confirmation current_password avatar].include?(e.attribute.to_s) } %>
  <% if detail_errors.any? %>
    <div role="alert" class="form-errors">
      <ul>
        <% detail_errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :full_name, "Full name" %>
    <%= form.text_field :full_name,
          placeholder: "Your full name",
          autocomplete: "name" %>
    <% user.errors[:full_name].each do |error| %>
      <span class="field-error" role="alert"><%= error %></span>
    <% end %>
  </div>

  <div class="field">
    <label>Email address</label>
    <p class="profile-email-readonly"><%= user.email_address %></p>
    <span class="field-hint">Changing your email will require re-verification.</span>
  </div>

  <div class="profile-form-actions">
    <%= form.submit "Save details", class: "btn-primary" %>
  </div>
<% end %>
