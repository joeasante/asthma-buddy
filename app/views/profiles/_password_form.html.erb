<%= form_with model: user, url: profile_path, method: :patch do |form| %>
  <input type="hidden" name="_profile_section" value="password">

  <% password_errors = user.errors.select { |e| %w[password password_confirmation current_password].include?(e.attribute.to_s) } %>
  <% if password_errors.any? %>
    <div role="alert" class="form-errors">
      <ul>
        <% password_errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <label for="user_current_password">Current password</label>
    <div class="field-password" data-controller="password-visibility">
      <%= password_field_tag "user[current_password]",
            nil,
            id: "user_current_password",
            autocomplete: "current-password",
            placeholder: "Your current password",
            data: { "password-visibility-target": "input" } %>
      <%= render "password_toggle" %>
    </div>
    <% user.errors[:current_password].each do |error| %>
      <span class="field-error" role="alert"><%= error %></span>
    <% end %>
  </div>

  <div class="field">
    <%= form.label :password, "New password" %>
    <div class="field-password" data-controller="password-visibility">
      <%= form.password_field :password,
            autocomplete: "new-password",
            placeholder: "At least 8 characters",
            data: { "password-visibility-target": "input" } %>
      <%= render "password_toggle" %>
    </div>
    <% user.errors[:password].each do |error| %>
      <span class="field-error" role="alert"><%= error %></span>
    <% end %>
  </div>

  <div class="field">
    <%= form.label :password_confirmation, "Confirm new password" %>
    <div class="field-password" data-controller="password-visibility">
      <%= form.password_field :password_confirmation,
            autocomplete: "new-password",
            placeholder: "Repeat new password",
            data: { "password-visibility-target": "input" } %>
      <%= render "password_toggle" %>
    </div>
  </div>

  <div class="profile-form-actions">
    <%= form.submit "Change password", class: "btn-primary" %>
  </div>
<% end %>
