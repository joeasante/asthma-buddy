<% content_for :title, "Sign in" %>

<% if flash[:alert].present? %>
  <p role="alert" class="flash flash--alert"><%= flash[:alert] %></p>
<% end %>

<h1>Sign in</h1>

<%= form_with url: session_path do |form| %>
  <div>
    <%= form.label :email_address, "Email address" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address] %>
  </div>

  <div>
    <%= form.label :password, "Password" %>
    <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72 %>
  </div>

  <%= form.submit "Sign in" %>
<% end %>

<p><%= link_to "Forgot password?", new_password_path %></p>
<p><%= link_to "Don't have an account? Sign up", new_registration_path %></p>
