<% content_for :title, "Sign in — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Sign in to Asthma Buddy to track your symptoms, peak flow readings, and medication adherence."><% end %>

<div class="auth-card">
  <%= link_to "Asthma Buddy", root_path, class: "auth-brand" %>

  <% if flash[:alert].present? %>
    <p role="alert" class="flash flash--alert"><%= flash[:alert] %></p>
  <% end %>

  <h1>Sign in</h1>

  <%= form_with url: session_path do |form| %>
    <div class="field">
      <%= form.label :email_address, "Email address" %>
      <%= form.email_field :email_address,
            required: true,
            autofocus: true,
            autocomplete: "username",
            value: params[:email_address] %>
    </div>

    <%= render "shared/password_field",
          form: form,
          field: :password,
          label_text: "Password",
          autocomplete: "current-password" %>

    <div class="field-forgot">
      <%= link_to "Forgot password?", new_password_path %>
    </div>

    <%= form.submit "Sign in" %>
  <% end %>

  <div class="auth-links">
    <% if registration_open? %><p>Don't have an account? <%= link_to "Create one", new_registration_path %></p><% end %>
    <p>Need a verification email? <%= link_to "Resend it", new_email_verification_path %></p>
  </div>
</div>
