<% content_for :title, "Medical History Entry — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Details of a medical history entry — event type, dates, and notes."><% end %>

<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Medical History", health_events_path, class: "breadcrumb-link" %>
  <span class="breadcrumb-sep" aria-hidden="true">›</span>
  <span class="breadcrumb-current">Entry</span>
</nav>

<div class="page-header">
  <div class="page-header-main">
    <div class="page-header-left">
      <h1>Medical History Entry</h1>
    </div>
    <div class="page-header-actions">
      <%= link_to "Edit", edit_health_event_path(@health_event), class: "btn-secondary" %>
      <%= button_to "Delete", health_event_path(@health_event),
            method: :delete,
            class: "btn-delete",
            form: { data: { turbo: false, turbo_confirm: "Delete this medical event? This cannot be undone." } } %>
    </div>
  </div>
</div>

<div class="section-card">
  <div class="detail-body">
    <div class="event-row event-row--flat">
      <div class="event-row-body">
        <div class="event-row-meta">
          <span class="event-badge event-badge--<%= @health_event.event_type_css_modifier %>">
            <%= @health_event.event_type_label %>
          </span>
          <% if @health_event.ongoing? %>
            <span class="event-ongoing-badge">Ongoing</span>
          <% end %>
        </div>

        <dl class="event-show-dl">
          <div class="event-show-dl-row">
            <dt class="event-show-dt"><%= @health_event.point_in_time? ? "Date" : "Started" %></dt>
            <dd class="event-show-dd">
              <time datetime="<%= @health_event.recorded_at.iso8601 %>">
                <%= @health_event.recorded_at.strftime("%-d %B %Y") %>
              </time>
            </dd>
          </div>

          <% unless @health_event.point_in_time? %>
            <div class="event-show-dl-row">
              <dt class="event-show-dt">Ended</dt>
              <dd class="event-show-dd">
                <% if @health_event.ended_at.present? %>
                  <time datetime="<%= @health_event.ended_at.iso8601 %>">
                    <%= @health_event.ended_at.strftime("%-d %B %Y") %>
                  </time>
                <% else %>
                  <span class="event-show-ongoing">Ongoing</span>
                <% end %>
              </dd>
            </div>

            <% if @health_event.formatted_duration.present? %>
              <div class="event-show-dl-row">
                <dt class="event-show-dt">Duration</dt>
                <dd class="event-show-dd">
                  <span class="event-row-duration"><%= @health_event.formatted_duration %></span>
                </dd>
              </div>
            <% end %>
          <% end %>
        </dl>

        <% if @health_event.notes.body.present? %>
          <div class="event-row-notes">
            <%= @health_event.notes %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if @illness_symptom_logs %>
  <div class="section-card illness-symptoms-card">
    <div class="illness-symptoms-header">
      <h2 class="illness-symptoms-title">
        Symptoms during this illness
        <% if @illness_symptom_logs.any? %>
          <span class="illness-symptoms-count">(<%= pluralize(@illness_symptom_logs.count, "entry") %>)</span>
        <% end %>
      </h2>
    </div>
    <% if @illness_symptom_logs.any? %>
      <div class="illness-symptom-cards">
        <% @illness_symptom_logs.each do |log| %>
          <%= render "symptom_logs/timeline_row", symptom_log: log %>
        <% end %>
      </div>
    <% else %>
      <p class="illness-symptoms-empty">No symptoms were logged during this period.</p>
    <% end %>
  </div>
<% end %>
