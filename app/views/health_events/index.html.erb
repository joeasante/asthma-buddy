<% content_for :title, "Medical History" %>

<div class="page-header">
  <div class="page-header-eyebrow">
    <span class="eyebrow-stat" id="health_events_count"><strong><%= @header_event_count %></strong> <%= "event".pluralize(@header_event_count) %> recorded</span>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
          <path d="M9 16l2 2 4-4"/>
        </svg>
      </div>
      <div>
        <h1>Medical History</h1>
        <p class="page-header-subtitle">GP visits, hospital stays, illnesses, and medication changes</p>
      </div>
    </div>
    <div class="page-header-actions">
      <%= link_to new_health_event_path, class: "btn-primary" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="margin-right: 0.375rem;">
          <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        Add event
      <% end %>
    </div>
  </div>
</div>

<div class="section-card">
  <div id="health_events_list">
    <%= render "list", grouped_events: @grouped_events %>
  </div>
</div>
