<% content_for :title, "Settings — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Account settings — manage your profile, medications, and notification preferences."><% end %>

<div class="page-header">
  <div class="page-header-eyebrow">
    <span class="eyebrow-section">Your Account</span>
    <% if Current.user.admin? %>
      <span class="eyebrow-pill" style="background: var(--brand); color: #fff; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; font-size: 0.6875rem;">Admin</span>
    <% end %>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
      </div>
      <div>
        <h1>Settings</h1>
        <p class="page-header-subtitle">Manage your account and preferences</p>
      </div>
    </div>
  </div>
</div>

<div class="settings-nav-grid">
  <a href="<%= profile_path %>" class="section-card section-card--nav" aria-label="Profile settings">
    <div class="settings-nav-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <circle cx="12" cy="8" r="3.25" stroke="currentColor" stroke-width="1.75"/>
        <path d="M4.5 20c0-3.59 3.358-6.5 7.5-6.5s7.5 2.91 7.5 6.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="settings-nav-body">
      <p class="settings-nav-title">Profile</p>
      <p class="settings-nav-description">Update your name, avatar, and personal best.</p>
    </div>
    <span class="settings-nav-chevron" aria-hidden="true"></span>
  </a>
  <a href="<%= settings_medications_path %>" class="section-card section-card--nav" aria-label="Medications settings">
    <div class="settings-nav-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <path d="M9 3H15L17 7H7L9 3Z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
        <rect x="4" y="7" width="16" height="14" rx="1.5" stroke="currentColor" stroke-width="1.75"/>
        <line x1="12" y1="11" x2="12" y2="17" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        <line x1="9" y1="14" x2="15" y2="14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="settings-nav-body">
      <p class="settings-nav-title">Medications</p>
      <p class="settings-nav-description">Manage your inhalers, track doses, and monitor stock levels.</p>
    </div>
    <span class="settings-nav-chevron" aria-hidden="true"></span>
  </a>
  <a href="<%= settings_security_path %>" class="section-card section-card--nav" aria-label="Security settings">
    <div class="settings-nav-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="settings-nav-body">
      <p class="settings-nav-title">Security<%= ' <span class="badge badge--enabled">MFA Enabled</span>'.html_safe if Current.user.otp_required_for_login? %></p>
      <p class="settings-nav-description">Manage two-factor authentication and recovery codes.</p>
    </div>
    <span class="settings-nav-chevron" aria-hidden="true"></span>
  </a>
  <a href="<%= settings_billing_path %>" class="section-card section-card--nav" aria-label="Billing settings">
    <div class="settings-nav-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <rect x="1" y="4" width="22" height="16" rx="2" stroke="currentColor" stroke-width="1.75"/>
        <line x1="1" y1="10" x2="23" y2="10" stroke="currentColor" stroke-width="1.75"/>
      </svg>
    </div>
    <div class="settings-nav-body">
      <p class="settings-nav-title">Billing<%= ' <span class="badge badge--enabled">Premium</span>'.html_safe if Current.user.premium? && !Current.user.admin? %></p>
      <p class="settings-nav-description">Manage your subscription plan and billing details.</p>
    </div>
    <span class="settings-nav-chevron" aria-hidden="true"></span>
  </a>
  <a href="<%= settings_api_key_path %>" class="section-card section-card--nav" aria-label="API Key settings">
    <div class="settings-nav-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="settings-nav-body">
      <p class="settings-nav-title">API Key<%= ' <span class="badge badge--enabled">Active</span>'.html_safe if Current.user.api_key_active? %></p>
      <p class="settings-nav-description">Generate and manage your API key for programmatic access.</p>
    </div>
    <span class="settings-nav-chevron" aria-hidden="true"></span>
  </a>
  <% if Current.user.admin? %>
    <a href="/jobs" class="section-card section-card--nav" aria-label="Mission Control">
      <div class="settings-nav-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.75"/>
          <path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="settings-nav-body">
        <p class="settings-nav-title">Mission Control <span class="badge badge--admin">Admin</span></p>
        <p class="settings-nav-description">Monitor background jobs and queue health.</p>
      </div>
      <span class="settings-nav-chevron" aria-hidden="true"></span>
    </a>
    <a href="<%= admin_users_path %>" class="section-card section-card--nav" aria-label="Admin">
      <div class="settings-nav-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.75"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="settings-nav-body">
        <p class="settings-nav-title">Admin <span class="badge badge--admin">Admin</span></p>
        <p class="settings-nav-description">Manage users and view platform stats.</p>
      </div>
      <span class="settings-nav-chevron" aria-hidden="true"></span>
    </a>
  <% end %>
</div>
