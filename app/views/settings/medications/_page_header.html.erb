<div class="page-header" id="medications-page-header">
  <div class="page-header-eyebrow">
    <span class="eyebrow-stat"><strong><%= medication_count %></strong> <%= "medication".pluralize(medication_count) %></span>
    <% if medication_count > 0 %>
      <span class="eyebrow-dot" aria-hidden="true"></span>
      <% if low_stock_count > 0 %>
        <span class="eyebrow-pill eyebrow-pill--amber"><%= low_stock_count %> low stock</span>
      <% else %>
        <span class="eyebrow-pill eyebrow-pill--green">All stocked</span>
      <% end %>
    <% end %>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="9" width="18" height="6" rx="3"/>
          <line x1="12" y1="9" x2="12" y2="15"/>
        </svg>
      </div>
      <div>
        <h1>Medications</h1>
        <p class="page-header-subtitle">Your inhalers and daily dose tracking</p>
      </div>
    </div>
    <div class="page-header-actions">
      <%= link_to "Preventer History", preventer_history_path, class: "btn-secondary btn-sm" %>
      <%= link_to "+ Add medication", new_settings_medication_path, class: "btn-primary btn-sm" %>
    </div>
  </div>
</div>
