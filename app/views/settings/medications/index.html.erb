<% content_for :title, "Medications — Asthma Buddy" %>

<%= render "page_header", medication_count: @header_medication_count, low_stock_count: @header_low_stock_count %>

<div class="section-card">
  <div class="med-list" id="medications_list">
    <% if @visible_medications.any? %>
      <% @visible_medications.each do |medication| %>
        <%= render medication_partial(medication), medication: medication %>
      <% end %>
    <% else %>
      <%= render "medications_empty_state" %>
    <% end %>
  </div>
</div>

<%# Past courses — hidden entirely when empty (per locked decision) %>
<% if @archived_courses.any? %>
  <%= render "settings/medications/past_courses", archived_courses: @archived_courses %>
<% end %>
