<%= form_with model: [:settings, medication], id: "medication_form",
      data: { turbo: local_assigns.fetch(:use_turbo, true), controller: "course-toggle" } do |form| %>
  <% if medication.errors.any? %>
    <div class="field-errors" role="alert" aria-live="assertive">
      <p><%= pluralize(medication.errors.count, "error") %> prevented this medication from being saved:</p>
      <ul>
        <% medication.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name, "Medication name" %>
    <%= form.text_field :name, placeholder: "e.g. Ventolin, Clenil Modulite", required: true,
          "aria-describedby": medication.errors[:name].any? ? "name-error" : nil %>
    <% if medication.errors[:name].any? %>
      <p class="field-error" id="name-error"><%= medication.errors[:name].first %></p>
    <% end %>
  </div>

  <div class="field">
    <%= form.label :medication_type, "Type" %>
    <%= form.select :medication_type,
          Medication.medication_types.keys.sort.map { |k| [k.humanize, k] },
          { include_blank: "Select a type", selected: medication.medication_type },
          { required: true, "aria-describedby": medication.errors[:medication_type].any? ? "type-error" : nil } %>
    <% if medication.errors[:medication_type].any? %>
      <p class="field-error" id="type-error"><%= medication.errors[:medication_type].first %></p>
    <% end %>
  </div>

  <div class="field">
    <%= form.label :dose_unit, "Dose unit" %>
    <%= form.select :dose_unit,
          Medication.dose_units.keys.map { |k| [k.humanize.capitalize, k] },
          { selected: medication.dose_unit || "puffs" },
          {} %>
    <p class="field-hint">Puffs for inhalers, tablets for oral courses, ml for liquid medications.</p>
  </div>

  <%# Course toggle checkbox %>
  <div class="field field--checkbox">
    <%= form.check_box :course, data: { "course-toggle-target": "checkbox", action: "change->course-toggle#toggle" } %>
    <%= form.label :course, "This is a temporary course (e.g. prednisolone tablets)" %>
  </div>

  <%# Inhaler-specific fields — hidden when "course" is checked %>
  <div data-course-toggle-target="inhalerFields">

    <div class="field">
      <%= form.label :standard_dose_puffs, "Standard dose (puffs)" %>
      <%= form.number_field :standard_dose_puffs, min: 1, step: 1 %>
      <% if medication.errors[:standard_dose_puffs].any? %>
        <p class="field-error"><%= medication.errors[:standard_dose_puffs].first %></p>
      <% end %>
    </div>

    <div class="field">
      <%= form.label :starting_dose_count, "Starting dose count" %>
      <%= form.number_field :starting_dose_count, min: 0, step: 1 %>
      <p class="field-hint">Enter the total number of puffs when the inhaler is full. A standard reliever inhaler usually has 200 puffs.</p>
      <% if medication.errors[:starting_dose_count].any? %>
        <p class="field-error"><%= medication.errors[:starting_dose_count].first %></p>
      <% end %>
    </div>

    <fieldset class="field-group">
      <legend>Optional</legend>

      <div class="field">
        <%= form.label :sick_day_dose_puffs, "Sick-day dose (puffs)" %>
        <%= form.number_field :sick_day_dose_puffs, min: 1, step: 1 %>
        <p class="field-hint">Leave blank if not applicable.</p>
      </div>

      <div data-course-toggle-target="dosesPerDayField">
        <div class="field">
          <%= form.label :doses_per_day, "Doses per day" %>
          <%= form.number_field :doses_per_day, min: 1, step: 1 %>
          <p class="field-hint">Required for preventer adherence tracking. Leave blank for relievers.</p>
        </div>
      </div>

    </fieldset>

  </div>

  <%# Course date fields — shown only when checkbox is checked %>
  <div data-course-toggle-target="courseFields" hidden>
    <fieldset class="field-group field-group--course">
      <legend>Course dates</legend>

      <div class="field">
        <%= form.label :starts_on, "Start date" %>
        <%= form.date_field :starts_on, required: medication.course %>
        <% if medication.errors[:starts_on].any? %>
          <p class="field-error"><%= medication.errors[:starts_on].first %></p>
        <% end %>
      </div>

      <div class="field">
        <%= form.label :ends_on, "End date" %>
        <%= form.date_field :ends_on, required: medication.course %>
        <% if medication.errors[:ends_on].any? %>
          <p class="field-error"><%= medication.errors[:ends_on].first %></p>
        <% end %>
      </div>

      <div class="field">
        <%= form.label :standard_dose_puffs, "Dose per session" %>
        <%= form.number_field :standard_dose_puffs, min: 1, step: 1 %>
        <p class="field-hint">Number of tablets/puffs per dose session.</p>
        <% if medication.errors[:standard_dose_puffs].any? %>
          <p class="field-error"><%= medication.errors[:standard_dose_puffs].first %></p>
        <% end %>
      </div>

      <div class="field">
        <%= form.label :doses_per_day, "Sessions per day" %>
        <%= form.number_field :doses_per_day, min: 1, step: 1 %>
        <p class="field-hint">How many times per day this course is taken.</p>
      </div>

    </fieldset>
  </div>

  <div class="form-actions">
    <%= form.submit medication.persisted? ? "Update medication" : "Add medication", class: "btn-primary" %>
    <%= link_to "Cancel", settings_medications_path, class: "btn-cancel" %>
  </div>

<% end %>

<% if medication.persisted? %>
  <div class="form-delete-zone">
    <%= button_to "Delete medication", settings_medication_path(medication), method: :delete,
          class: "btn-delete btn-delete--full",
          form: { data: { turbo: true, turbo_confirm: "Delete #{medication.name}? All dose history will also be deleted. This can't be undone." } } %>
  </div>
<% end %>
