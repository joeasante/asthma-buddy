<% content_for :title, "Add Medication — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Add a new medication — enter your inhaler or medication details to start tracking doses and stock."><% end %>

<div class="page-header">
  <h1>Add medication</h1>
  <%= link_to "Cancel", settings_medications_path, class: "btn-secondary" %>
</div>

<div class="section-card">
  <%# turbo: false — after create, the controller redirects to the list via HTML. %>
  <%= render "form", medication: @medication, use_turbo: false %>
</div>
