<%# Replace the entire med row — picks up updated remaining_doses, low_stock? border, and history %>
<%= turbo_stream.replace dom_id(@medication),
      partial: "settings/medications/medication",
      locals: { medication: @medication } %>

<%# Toast — picked up by toast_controller.js %>
<%= turbo_stream.replace "flash-messages" do %>
  <div id="flash-messages" data-controller="toast" data-toast-message="Dose logged." data-toast-variant="success"></div>
<% end %>
