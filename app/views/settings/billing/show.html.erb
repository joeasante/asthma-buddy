<% content_for :title, "Billing — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Manage your subscription plan and billing details."><% end %>

<div class="page-header">
  <div class="page-header-eyebrow">
    <span class="eyebrow-section">Settings</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity: 0.4; margin: 0 0.25rem;"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="eyebrow-section">Billing</span>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="4" width="22" height="16" rx="2"/>
          <line x1="1" y1="10" x2="23" y2="10"/>
        </svg>
      </div>
      <div>
        <h1>Billing</h1>
        <p class="page-header-subtitle">Manage your subscription plan and billing</p>
      </div>
    </div>
  </div>
</div>

<% if flash[:notice].present? %>
  <p role="status" class="flash flash--notice"><%= flash[:notice] %></p>
<% end %>

<div class="section-card">
  <div class="section-card-header">
    <h2 class="section-card-title">Current Plan</h2>
    <% case @user.subscription_status %>
    <% when "active" %>
      <span class="badge badge--enabled">Active</span>
    <% when "cancelling" %>
      <span class="badge badge--warning">Cancelling</span>
    <% when "past_due" %>
      <span class="badge badge--danger">Past Due</span>
    <% else %>
      <span class="badge badge--disabled">Free</span>
    <% end %>
  </div>
  <div class="section-card-body">
    <div class="billing-plan-name">
      <% if @user.admin? %>
        <strong>Premium (Admin)</strong>
      <% else %>
        <strong><%= @user.plan_name %></strong>
      <% end %>
    </div>

    <% if @user.subscription_status == "cancelling" && @subscription&.ends_at.present? %>
      <p class="billing-notice">
        Your subscription will end on <strong><%= @subscription.ends_at.strftime("%B %-d, %Y") %></strong>.
        You will retain premium access until then.
      </p>
    <% end %>

    <% if @user.subscription_status == "active" && @user.next_billing_date.present? %>
      <p>Next billing date: <strong><%= @user.next_billing_date.strftime("%B %-d, %Y") %></strong></p>
    <% end %>

    <% if @user.free? %>
      <div class="billing-limits">
        <h3>Free Plan Limits</h3>
        <ul>
          <li><%= PLANS[:free][:features][:symptom_log_history_days] %> days symptom log history</li>
          <li><%= PLANS[:free][:features][:peak_flow_history_days] %> days peak flow history</li>
          <li>No API access</li>
        </ul>
      </div>
    <% end %>

    <div class="billing-actions">
      <% if @user.free? %>
        <%= button_to "Upgrade to Premium", checkout_settings_billing_path, class: "btn-primary", data: { turbo: false } %>
      <% elsif @user.premium? && !@user.admin? %>
        <%= button_to "Manage Subscription", portal_settings_billing_path, class: "btn-secondary", data: { turbo: false } %>
      <% end %>
    </div>
  </div>
</div>

<div class="form-actions">
  <%= link_to "Back to Settings", settings_path, class: "btn-cancel" %>
</div>
