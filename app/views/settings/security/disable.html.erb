<% content_for :title, "Disable Two-Factor Authentication — Asthma Buddy" %>

<div class="page-header">
  <div class="page-header-eyebrow">
    <span class="eyebrow-section">Settings</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity: 0.4; margin: 0 0.25rem;"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="eyebrow-section">Security</span>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div>
        <h1>Disable Two-Factor Authentication</h1>
        <p class="page-header-subtitle">Remove the extra security from your account</p>
      </div>
    </div>
  </div>
</div>

<% if flash[:alert].present? %>
  <p role="alert" class="flash flash--alert"><%= flash[:alert] %></p>
<% end %>

<div class="section-card">
  <div class="section-card-body">
    <div class="mfa-warning-card mfa-warning-card--danger">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
      <p>This will remove two-factor authentication from your account. You will only need your password to sign in.</p>
    </div>

    <%= form_with url: confirm_disable_settings_security_path do |form| %>
      <div class="field">
        <%= form.label :password, "Enter your password to confirm" %>
        <%= form.password_field :password,
              required: true,
              autofocus: true,
              autocomplete: "current-password" %>
      </div>

      <div class="form-actions">
        <%= form.submit "Disable Two-Factor Authentication", class: "btn-delete" %>
        <%= link_to "Cancel", settings_security_path, class: "btn-cancel" %>
      </div>
    <% end %>
  </div>
</div>
