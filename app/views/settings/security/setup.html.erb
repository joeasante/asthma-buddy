<% content_for :title, "Set Up Two-Factor Authentication — Asthma Buddy" %>

<div class="page-header">
  <div class="page-header-eyebrow">
    <span class="eyebrow-section">Settings</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity: 0.4; margin: 0 0.25rem;"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="eyebrow-section">Security</span>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div>
        <h1>Set Up Two-Factor Authentication</h1>
        <p class="page-header-subtitle">Secure your account with an authenticator app</p>
      </div>
    </div>
  </div>
</div>

<% if flash[:alert].present? %>
  <p role="alert" class="flash flash--alert"><%= flash[:alert] %></p>
<% end %>

<div class="section-card">
  <div class="section-card-body">
    <div class="mfa-setup-steps">
      <div class="mfa-step">
        <p class="mfa-step-number">1</p>
        <div class="mfa-step-content">
          <p class="mfa-step-title">Scan this QR code with your authenticator app</p>
          <p class="mfa-step-hint">Use an app like Google Authenticator, Authy, or 1Password.</p>
          <div class="mfa-qr-container" style="background: #fff; padding: 1rem; display: inline-block; border-radius: 8px;">
            <%= @qr_svg.html_safe %>
          </div>
        </div>
      </div>

      <div class="mfa-step">
        <p class="mfa-step-number">2</p>
        <div class="mfa-step-content">
          <p class="mfa-step-title">Can't scan? Enter this key manually:</p>
          <code class="mfa-manual-key"><%= @manual_key %></code>
        </div>
      </div>

      <div class="mfa-step">
        <p class="mfa-step-number">3</p>
        <div class="mfa-step-content">
          <p class="mfa-step-title">Enter the 6-digit code from your app to verify:</p>

          <%= form_with url: confirm_setup_settings_security_path do |form| %>
            <div class="field">
              <%= form.label :otp_code, "Verification code" %>
              <%= form.text_field :otp_code,
                    required: true,
                    autofocus: true,
                    autocomplete: "one-time-code",
                    inputmode: "numeric",
                    maxlength: 6,
                    pattern: "[0-9]*",
                    placeholder: "000000" %>
            </div>

            <div class="form-actions">
              <%= form.submit "Verify and Enable", class: "btn-primary" %>
              <%= link_to "Cancel", settings_security_path, class: "btn-cancel" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
