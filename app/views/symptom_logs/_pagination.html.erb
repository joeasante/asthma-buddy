<% if total_pages > 1 %>
  <%
    active_symptom_type ||= nil
    active_severity     ||= nil
    # Build shared filter params for all pagination links
    filter_params = {
      preset:       active_preset,
      start_date:   start_date,
      end_date:     end_date,
      symptom_type: active_symptom_type,
      severity:     active_severity
    }.compact_blank

    # Determine the visible page window (max 5 pages centred on current)
    window_start  = [current_page - 2, 1].max
    window_end    = [current_page + 2, total_pages].min
    visible_pages = (window_start..window_end).to_a
  %>
  <nav class="pagination" aria-label="Timeline pages">
    <span class="pagination-position">Page <%= current_page %> of <%= total_pages %></span>

    <div class="pagination-controls">
      <%# Previous %>
      <% if current_page > 1 %>
        <%= link_to "← Prev",
              symptom_logs_path(filter_params.merge(page: current_page - 1)),
              class: "pagination-btn",
              data:  { turbo_frame: "timeline_content" } %>
      <% end %>

      <%# First page + ellipsis if window doesn't start at 1 %>
      <% if window_start > 1 %>
        <%= link_to "1",
              symptom_logs_path(filter_params.merge(page: 1)),
              class: "pagination-btn",
              data:  { turbo_frame: "timeline_content" } %>
        <% if window_start > 2 %>
          <span class="pagination-ellipsis" aria-hidden="true">…</span>
        <% end %>
      <% end %>

      <%# Visible page numbers %>
      <% visible_pages.each do |p| %>
        <%= link_to p.to_s,
              symptom_logs_path(filter_params.merge(page: p)),
              class: "pagination-btn#{p == current_page ? " pagination-btn--current" : ""}",
              aria:  { current: p == current_page ? "page" : nil },
              data:  { turbo_frame: "timeline_content" } %>
      <% end %>

      <%# Last page + ellipsis if window doesn't end at total_pages %>
      <% if window_end < total_pages %>
        <% if window_end < total_pages - 1 %>
          <span class="pagination-ellipsis" aria-hidden="true">…</span>
        <% end %>
        <%= link_to total_pages.to_s,
              symptom_logs_path(filter_params.merge(page: total_pages)),
              class: "pagination-btn",
              data:  { turbo_frame: "timeline_content" } %>
      <% end %>

      <%# Next %>
      <% if current_page < total_pages %>
        <%= link_to "Next →",
              symptom_logs_path(filter_params.merge(page: current_page + 1)),
              class: "pagination-btn",
              data:  { turbo_frame: "timeline_content" } %>
      <% end %>
    </div>
  </nav>
<% end %>
