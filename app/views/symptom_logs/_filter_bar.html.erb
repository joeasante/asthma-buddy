<div class="filter-bar" role="search" aria-label="Filter symptom history">

  <%# Date preset chips %>
  <div class="filter-section">
    <span class="filter-section-label">Period</span>
    <div class="filter-presets">
      <% [["7", "7 days"], ["30", "30 days"], ["90", "90 days"], ["all", "All time"]].each do |value, label| %>
        <%= link_to label,
              symptom_logs_path(
                preset:       value,
                symptom_type: active_symptom_type,
                severity:     active_severity
              ),
              class: "filter-chip #{"filter-chip--active" if active_preset == value}",
              aria:  { pressed: active_preset == value },
              data:  { turbo_frame: "timeline_content" } %>
      <% end %>
    </div>
  </div>

  <%# Symptom type chips %>
  <div class="filter-section">
    <span class="filter-section-label">Type</span>
    <div class="filter-presets">
      <% [["", "All"], ["wheezing", "Wheezing"], ["coughing", "Coughing"],
          ["shortness_of_breath", "Shortness of breath"], ["chest_tightness", "Chest tightness"]].each do |value, label| %>
        <%= link_to label,
              symptom_logs_path(
                preset:       active_preset,
                symptom_type: value,
                severity:     active_severity
              ),
              class: "filter-chip #{"filter-chip--active" if active_symptom_type.to_s == value}",
              aria:  { pressed: active_symptom_type.to_s == value },
              data:  { turbo_frame: "timeline_content" } %>
      <% end %>
    </div>
  </div>

  <%# Severity chips %>
  <div class="filter-section">
    <span class="filter-section-label">Severity</span>
    <div class="filter-presets">
      <% [["", "All"], ["mild", "Mild"], ["moderate", "Moderate"], ["severe", "Severe"]].each do |value, label| %>
        <%= link_to label,
              symptom_logs_path(
                preset:       active_preset,
                symptom_type: active_symptom_type,
                severity:     value
              ),
              class: "filter-chip #{"filter-chip--active" if active_severity.to_s == value}",
              aria:  { pressed: active_severity.to_s == value },
              data:  { turbo_frame: "timeline_content" } %>
      <% end %>
    </div>
  </div>

  <%# Custom date range %>
  <%= form_with url: symptom_logs_path, method: :get,
        data: { turbo_frame: "timeline_content" },
        class: "filter-custom-dates" do |f| %>
    <input type="hidden" name="preset"       value="custom">
    <input type="hidden" name="symptom_type" value="<%= active_symptom_type %>">
    <input type="hidden" name="severity"     value="<%= active_severity %>">
    <div class="filter-date-inputs">
      <%= f.label :start_date, "From" %>
      <%= f.date_field :start_date, value: start_date, class: "date-input" %>
      <%= f.label :end_date, "To" %>
      <%= f.date_field :end_date, value: end_date, class: "date-input" %>
      <%= f.submit "Apply", class: "btn-apply-dates" %>
    </div>
  <% end %>

</div>
