<div class="filter-bar" role="search" aria-label="Filter symptom history">

  <%# Row 1: Period — primary control %>
  <div class="filter-row" role="group" aria-label="Time period">
    <% [["7", "7d"], ["30", "30d"], ["90", "3m"], ["all", "All"], ["custom", "Custom"]].each do |value, label| %>
      <%= link_to label,
            symptom_logs_path(preset: value, symptom_type: active_symptom_type, severity: active_severity),
            class: "filter-chip #{"filter-chip--active" if active_preset == value}",
            aria:  { pressed: (active_preset == value).to_s },
            data:  { turbo_frame: "timeline_content" } %>
    <% end %>
    <% if active_symptom_type.present? || active_severity.present? %>
      <%= link_to "Clear filters",
            symptom_logs_path,
            class: "filter-clear",
            aria:  { label: "Clear all filters" },
            data:  { turbo_frame: "timeline_content" } %>
    <% end %>
  </div>

  <%# Row 2: Severity %>
  <div class="filter-row" role="group" aria-label="Severity filter">
    <% [["", "All"], ["mild", "Mild"], ["moderate", "Moderate"], ["severe", "Severe"]].each do |value, label| %>
      <%= link_to label,
            symptom_logs_path(preset: active_preset, symptom_type: active_symptom_type, severity: value),
            class: "filter-chip #{"filter-chip--#{value}" if value.present?} #{"filter-chip--active" if active_severity.to_s == value}",
            aria:  { pressed: (active_severity.to_s == value).to_s },
            data:  { turbo_frame: "timeline_content" } %>
    <% end %>
  </div>

  <%# Row 3: Symptom type %>
  <div class="filter-row" role="group" aria-label="Symptom type filter">
    <% [["", "All"], ["wheezing", "Wheezing"], ["coughing", "Coughing"],
        ["shortness_of_breath", "Breathlessness"], ["chest_tightness", "Chest tightness"]].each do |value, label| %>
      <%= link_to label,
            symptom_logs_path(preset: active_preset, symptom_type: value, severity: active_severity),
            class: "filter-chip #{"filter-chip--active" if active_symptom_type.to_s == value}",
            aria:  { pressed: (active_symptom_type.to_s == value).to_s },
            data:  { turbo_frame: "timeline_content" } %>
    <% end %>
  </div>

  <%# Custom date range — revealed only when Custom preset is active %>
  <% if active_preset == "custom" || start_date.present? || end_date.present? %>
    <%= form_with url: symptom_logs_path, method: :get,
          data: { controller: "date-range", turbo_frame: "timeline_content" },
          class: "filter-dates" do |f| %>
      <input type="hidden" name="preset"       value="custom">
      <input type="hidden" name="symptom_type" value="<%= active_symptom_type %>">
      <input type="hidden" name="severity"     value="<%= active_severity %>">
      <div class="filter-date-row">
        <span class="filter-date-label">From</span>
        <%= f.date_field :start_date,
              value: start_date,
              class: "filter-date-input",
              aria: { label: "Start date" },
              data: { date_range_target: "start", action: "change->date-range#check" } %>
      </div>
      <div class="filter-date-row">
        <span class="filter-date-label">To</span>
        <%= f.date_field :end_date,
              value: end_date,
              class: "filter-date-input",
              aria: { label: "End date" },
              data: { date_range_target: "end", action: "change->date-range#check" } %>
      </div>
    <% end %>
  <% end %>

</div>
