<%= turbo_stream.replace "trend_bar" do %>
  <div id="trend_bar">
    <%= render "trend_bar", severity_counts: @severity_counts %>
  </div>
<% end %>
<%= turbo_stream.prepend "timeline_list", partial: "timeline_row", locals: { symptom_log: @symptom_log } %>
<%= turbo_stream.replace "symptom_log_form" do %>
  <%= render "form", symptom_log: Current.user.symptom_logs.new(recorded_at: Time.current.change(sec: 0)) %>
<% end %>
