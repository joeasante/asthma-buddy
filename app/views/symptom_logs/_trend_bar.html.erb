<% total = severity_counts.values.sum %>
<% if total > 0 %>
  <div class="chart-severity-legend">
    <% [[:mild, "Mild"], [:moderate, "Moderate"], [:severe, "Severe"]].each do |key, label| %>
      <% count = severity_counts[key] || 0 %>
      <% if count > 0 %>
        <span class="chart-severity-pill chart-severity-pill--<%= key %>">
          <span class="chart-severity-pill-dot" aria-hidden="true"></span>
          <%= label %> <strong><%= count %></strong>
        </span>
      <% end %>
    <% end %>
    <span class="chart-severity-total"><%= total %> total</span>
  </div>
<% end %>
