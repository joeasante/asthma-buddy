<% content_for :title, "Symptom Timeline" %>

<h1>Log a Symptom</h1>

<section aria-label="Log symptom form">
  <%= turbo_frame_tag "symptom_log_form" do %>
    <%= render "form", symptom_log: @symptom_log %>
  <% end %>
</section>

<section aria-label="Symptom timeline">
  <h2>Your Symptom History</h2>

  <%= render "filter_bar",
        active_preset: @active_preset,
        start_date: @start_date,
        end_date: @end_date %>

  <%= turbo_frame_tag "timeline_content" do %>
    <div id="trend_bar">
      <%= render "trend_bar", severity_counts: @severity_counts %>
    </div>

    <% if @symptom_logs.empty? %>
      <p class="timeline-empty-state">No symptoms recorded for this period. Try a wider date range or log your first entry above.</p>
    <% else %>
      <ol id="timeline_list" class="timeline-list" aria-label="Symptom entries">
        <% @symptom_logs.each do |log| %>
          <li><%= render "timeline_row", symptom_log: log %></li>
        <% end %>
      </ol>
      <%= render "pagination", current_page: @current_page, total_pages: @total_pages,
            active_preset: @active_preset, start_date: @start_date, end_date: @end_date %>
    <% end %>
  <% end %>
</section>
