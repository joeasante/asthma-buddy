<% content_for :title, "Symptom Logs — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Your symptom history — a timeline of logged asthma episodes, severity, and triggers."><% end %>

<%= render "page_header", last_log: @header_last_log, month_count: @header_month_count %>

<% if @history_limited %>
  <div class="section-card" style="border-left: 3px solid var(--brand); margin-bottom: 1.5rem;">
    <p style="margin: 0;">
      <strong>Free plan:</strong> Showing the last 30 days.
      <%= link_to "Upgrade to Premium", settings_billing_path %> for unlimited history.
    </p>
  </div>
<% end %>

<div id="symptoms-graph" class="section-card" data-controller="hash-scroll">
  <div class="section-card-header">
    <h2 class="section-card-title">History</h2>
  </div>

  <%= turbo_frame_tag "timeline_content" do %>
    <% if @chart_data&.any? %>
      <div class="chart-section"
           data-controller="chart"
           data-chart-type-value="symptoms"
           data-chart-data-value="<%= @chart_data.to_json %>">
        <div class="chart-canvas-wrapper">
          <canvas class="chart-canvas chart-canvas--symptoms"
                  aria-label="Symptom severity over time"
                  role="img">
          </canvas>
        </div>
      </div>
    <% end %>

    <%= render "filter_bar",
          active_preset:       @active_preset,
          start_date:          @start_date,
          end_date:            @end_date,
          active_symptom_type: @active_symptom_type,
          active_severity:     @active_severity %>

    <div id="trend_bar">
      <%= render "trend_bar",
            severity_counts: @severity_counts,
            active_severity: @active_severity,
            current_preset:  @active_preset %>
    </div>

    <% if @symptom_logs.empty? %>
      <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="8" y="6" width="32" height="36" rx="4" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            <path d="M16 17h16M16 23h16M16 29h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <circle cx="36" cy="36" r="7" fill="var(--surface)" stroke="currentColor" stroke-width="2"/>
            <path d="M36 33v3l1.5 1.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <% if @active_symptom_type.present? || @active_severity.present? || @start_date.present? || @end_date.present? %>
          <h3>No symptoms match these filters</h3>
          <p>Try adjusting the filters above to see more results.</p>
        <% else %>
          <h3>No symptoms logged yet</h3>
          <p>Tap the button above to log how you&rsquo;re feeling today.</p>
          <div class="empty-state-actions">
            <%= link_to "Log a symptom", new_symptom_log_path, class: "btn-primary" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <%# Skeleton rows — hidden normally, shown by CSS while turbo-frame is busy %>
      <div class="timeline-skeleton" aria-hidden="true">
        <div class="timeline-skeleton-row"></div>
        <div class="timeline-skeleton-row"></div>
        <div class="timeline-skeleton-row"></div>
      </div>

      <ol id="timeline_list" class="timeline-list" aria-label="Symptom entries">
        <% @symptom_logs.each do |log| %>
          <li><%= render "timeline_row", symptom_log: log %></li>
        <% end %>
      </ol>

      <%= render "pagination",
            current_page:        @current_page,
            total_pages:         @total_pages,
            active_preset:       @active_preset,
            start_date:          @start_date,
            end_date:            @end_date,
            active_symptom_type: @active_symptom_type,
            active_severity:     @active_severity %>
    <% end %>
  <% end %>
</div>
