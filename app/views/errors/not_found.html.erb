<% content_for :title, "Page Not Found — Asthma Buddy" %>

<div class="error-page">
  <span class="error-code" aria-hidden="true">404</span>
  <div class="error-content">
    <h1 class="error-heading">Page not found</h1>
    <p class="error-description">
      The page you were looking for doesn't exist or may have moved.
    </p>
    <%= link_to authenticated? ? dashboard_path : root_path, class: "btn-primary" do %>
      <%= authenticated? ? "Go to dashboard" : "Go to home page" %>
    <% end %>
  </div>
</div>
