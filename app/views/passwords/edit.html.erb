<% content_for :title, "Choose a new password — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Choose a new password for your Asthma Buddy account."><% end %>

<div class="auth-card">
  <%= link_to "Asthma Buddy", root_path, class: "auth-brand" %>

  <% if flash[:alert].present? %>
    <p role="alert" class="flash flash--alert"><%= flash[:alert] %></p>
    <div class="auth-links">
      <p><%= link_to "Request a new reset link", new_password_path %></p>
    </div>
  <% else %>
    <h1>Choose a new password</h1>

    <%= form_with url: password_path(params[:token]), method: :patch do |form| %>
      <%= render "shared/password_field",
            form: form,
            field: :password,
            label_text: "New password",
            autocomplete: "new-password",
            autofocus: true %>

      <%= render "shared/password_field",
            form: form,
            field: :password_confirmation,
            label_text: "Confirm new password",
            autocomplete: "new-password" %>

      <%= form.submit "Set new password" %>
    <% end %>

    <div class="auth-links">
      <p><%= link_to "Back to sign in", new_session_path %></p>
    </div>
  <% end %>
</div>
