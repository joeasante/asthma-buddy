<% content_for :title, "Forgot your password?" %>

<h1>Forgot your password?</h1>

<%= form_with url: passwords_path do |form| %>
  <div>
    <%= form.label :email_address, "Email address" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address] %>
  </div>

  <%= form.submit "Send reset link" %>
<% end %>

<p><%= link_to "Back to sign in", new_session_path %></p>
