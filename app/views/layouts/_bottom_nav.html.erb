<nav class="bottom-nav" aria-label="Primary navigation">
  <%= link_to dashboard_path,
        class: nav_tab_class(dashboard_path),
        aria: { current: nav_current(dashboard_path), label: "Home" } do %>
    <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>
    <span>Home</span>
  <% end %>

  <%= link_to peak_flow_readings_path,
        class: nav_tab_class(peak_flow_readings_path),
        aria: { current: nav_current(peak_flow_readings_path), label: "Peak Flow" } do %>
    <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
    </svg>
    <span>Peak Flow</span>
  <% end %>

  <%= link_to symptom_logs_path,
        class: nav_tab_class(symptom_logs_path),
        aria: { current: nav_current(symptom_logs_path), label: "Symptoms" } do %>
    <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
      <rect x="9" y="3" width="6" height="4" rx="1"/>
      <line x1="9" y1="12" x2="15" y2="12"/>
      <line x1="9" y1="16" x2="13" y2="16"/>
    </svg>
    <span>Symptoms</span>
  <% end %>

  <%= link_to health_events_path,
        class: nav_tab_class(health_events_path),
        aria: { current: nav_current(health_events_path), label: "History" } do %>
    <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <polyline points="12 6 12 12 16 14"/>
    </svg>
    <span>History</span>
  <% end %>

  <% notification_unread_count = Current.user.notifications.unread.count %>
  <%= link_to notifications_path,
        class: "#{nav_tab_class(notifications_path)} has-unread-badge",
        "data-unread-count": notification_unread_count,
        aria: { current: nav_current(notifications_path), label: "Notifications" } do %>
    <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <span>Alerts</span>
  <% end %>
</nav>
