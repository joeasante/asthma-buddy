<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Asthma Buddy" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <nav aria-label="Main navigation">
        <%= link_to "Asthma Buddy", root_path, class: "nav-brand" %>
        <div class="nav-auth">
          <% if authenticated? %>
            <span class="nav-user-email"><%= Current.user&.email_address %></span>
            <%= button_to "Sign out", session_path, method: :delete, class: "btn-sign-out" %>
          <% else %>
            <%= link_to "Sign in", new_session_path %>
            <%= link_to "Sign up", new_registration_path %>
          <% end %>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <% if notice.present? %>
        <p role="status" class="flash flash--notice"><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p role="alert" class="flash flash--alert"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>

    <footer>
      <p>Asthma Buddy</p>
    </footer>
  </body>
</html>
