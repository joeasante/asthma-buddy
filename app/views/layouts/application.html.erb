<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Asthma Buddy" %></title>
    <%= yield(:meta_description) if content_for?(:meta_description) %>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Trim to weights actually used — Inter 700 unused (headings use Plus Jakarta Sans) %>
    <%# Plus Jakarta Sans 600 unused (headings use 700/800 only) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="<%= asset_path 'favicon.svg' %>" type="image/svg+xml">
    <link rel="icon" href="<%= asset_path 'favicon.png' %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path 'favicon.png' %>">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%# Page-specific stylesheets injected via content_for :head in consuming views %>
    <%= yield :head %>
    <%# Cookie notice CSS — only when the banner will actually render %>
    <%= stylesheet_link_tag "cookie_notice", "data-turbo-track": "reload" unless authenticated? || cookies[:cookie_notice_dismissed].present? %>
    <% if authenticated? %>
      <%= stylesheet_link_tag "profile",           "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "charts",            "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "dashboard",         "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "peak_flow",         "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "settings",          "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "confirm_dialog",    "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "symptom_timeline",  "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "health_events",     "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "reliever_usage",    "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "medications",       "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "notifications",    "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "appointment_summary", "data-turbo-track": "reload" %>
      <%= stylesheet_link_tag "admin",           "data-turbo-track": "reload" if controller_path.start_with?("admin/") %>
    <% end %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="confirm" class="<%= 'has-bottom-nav' if authenticated? %>">
    <%# Skip link — must be first focusable element for keyboard/screen reader users (WCAG 2.4.1) %>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <dialog class="confirm-dialog"
            data-confirm-target="dialog"
            data-action="click->confirm#backdropClick">
      <p class="confirm-dialog-message" data-confirm-target="message"></p>
      <div class="confirm-dialog-actions">
        <button class="btn-confirm-cancel" data-action="confirm#dismiss">Cancel</button>
        <button class="btn-confirm-delete" data-action="confirm#accept">Remove</button>
      </div>
    </dialog>

    <header>
      <nav aria-label="Main navigation">
        <%= link_to "Asthma Buddy",
              authenticated? ? dashboard_path : root_path,
              class: "nav-brand" %>
        <div class="nav-auth">
          <% if authenticated? %>
            <%= link_to "Symptoms", symptom_logs_path,
                  class: nav_link_class(symptom_logs_path),
                  aria: { current: nav_current(symptom_logs_path) } %>
            <%= link_to "Peak Flow", peak_flow_readings_path,
                  class: nav_link_class(peak_flow_readings_path),
                  aria: { current: nav_current(peak_flow_readings_path) } %>
            <%= link_to "Medications", settings_medications_path,
                  class: nav_link_class(settings_medications_path),
                  aria: { current: nav_current(settings_medications_path) } %>
            <%= link_to "Medical History", health_events_path,
                  class: nav_link_class(health_events_path),
                  aria: { current: nav_current(health_events_path) } %>
            <%= render "layouts/nav_bell", unread_count: @unread_notification_count %>
            <div class="nav-user" data-controller="nav-dropdown">
              <button class="nav-avatar-btn"
                      data-action="click->nav-dropdown#toggle"
                      aria-haspopup="true"
                      aria-label="User menu">
                <% if Current.user.avatar.attached? %>
                  <%= image_tag Current.user.avatar.variant(resize_to_fill: [36, 36]),
                        class: "nav-avatar-img",
                        alt: Current.user.full_name.presence || "Profile" %>
                <% else %>
                  <span class="nav-avatar-initials" aria-hidden="true">
                    <%= (Current.user.full_name.presence || Current.user.email_address).first.upcase %>
                  </span>
                <% end %>
                <span class="nav-user-name">
                  <%= Current.user.full_name.presence || Current.user.email_address.split("@").first %>
                </span>
                <svg class="nav-avatar-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="nav-dropdown" data-nav-dropdown-target="menu" hidden>
                <%= link_to "Settings", settings_path, class: "nav-dropdown-item" %>
                <%= button_to "Sign out", session_path, method: :delete,
                      class: "nav-dropdown-item nav-dropdown-item--signout",
                      form: { style: "width: 100%" } %>
              </div>
            </div>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "nav-link" %>
            <% if registration_open? %><%= link_to "Get started", new_registration_path, class: "nav-link nav-link--cta" %><% end %>
          <% end %>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <%= render "layouts/flash" %>

      <%= yield %>
    </main>

    <% if authenticated? %>
      <%= render "layouts/bottom_nav" %>
    <% end %>

    <%= render "layouts/cookie_notice" unless authenticated? || cookies[:cookie_notice_dismissed].present? || controller_name == "errors" %>

    <%# Toast region — toasts are appended here by toast_controller.js %>
    <div id="toast-region" class="toast-region" aria-live="polite" aria-atomic="false"></div>

    <% if authenticated? %>
      <%# App footer — just legal links, no marketing copy inside the product %>
      <footer class="footer-app">
        <nav class="footer-nav" aria-label="Footer">
          <%= link_to "Privacy", privacy_path %>
          <%= link_to "Terms", terms_path %>
          <%= link_to "Cookies", cookie_policy_path %>
        </nav>
      </footer>
    <% else %>
      <footer>
        <p class="footer-copy">Asthma Buddy &mdash; track your breathing, understand your patterns</p>
        <nav class="footer-nav" aria-label="Footer">
          <%= link_to "Privacy", privacy_path %>
          <%= link_to "Terms", terms_path %>
          <%= link_to "Cookies", cookie_policy_path %>
        </nav>
        <p class="footer-legal">&copy; <%= Time.current.year %> Asthma Buddy</p>
      </footer>
    <% end %>
  </body>
</html>
