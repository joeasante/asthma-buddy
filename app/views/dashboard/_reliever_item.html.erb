<li class="dash-adherence-item dash-adherence-item--reliever">
  <%= link_to medication[:name],
        settings_medications_path(anchor: "medication_#{medication[:id]}"),
        class: "dash-adherence-name" %>
  <div class="dash-adherence-stats">
    <span class="dash-adherence-count"><%= medication[:today_puffs] %></span>
    <span class="dash-adherence-label">puffs today</span>
  </div>
  <div class="dash-adherence-actions">
    <%= button_to settings_medication_dose_logs_path(medication[:id]),
          params: { dose_log: { puffs: medication[:standard_dose_puffs] } },
          class: "dash-dose-btn",
          form: { style: "display: contents" },
          aria: { label: "Log #{medication[:standard_dose_puffs]} standard puffs of #{medication[:name]}" } do %>
      +<%= medication[:standard_dose_puffs] %> puffs
    <% end %>
    <% if active_illness && medication[:sick_day_dose_puffs].present? %>
      <%= button_to settings_medication_dose_logs_path(medication[:id]),
            params: { dose_log: { puffs: medication[:sick_day_dose_puffs] } },
            class: "dash-dose-btn dash-dose-btn--sick",
            form: { style: "display: contents" },
            aria: { label: "Log sick day dose: #{medication[:sick_day_dose_puffs]} puffs of #{medication[:name]}" } do %>
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
        </svg>
        +<%= medication[:sick_day_dose_puffs] %> puffs
      <% end %>
    <% end %>
  </div>
</li>
