<% content_for :title, "Dashboard — Asthma Buddy" %>
<% content_for :meta_description do %><meta name="description" content="Your asthma at a glance — today's peak flow, symptom summary, medication adherence, and low-stock alerts."><% end %>

<div class="page-header">
  <div class="page-header-eyebrow">
    <% if @todays_best_reading %>
      <% zone = @todays_best_reading.zone %>
      <span class="eyebrow-stat">Today: <strong><%= @todays_best_reading.value %> L/min</strong></span>
      <% if zone && @personal_best %>
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span class="eyebrow-pill eyebrow-pill--<%= @todays_best_reading.zone_css_modifier %>">
          <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor" aria-hidden="true"><circle cx="3" cy="3" r="3"/></svg>
          <%= zone.capitalize %> zone
        </span>
      <% end %>
    <% else %>
      <span class="eyebrow-stat">No peak flow reading today</span>
    <% end %>
    <% if @active_illness %>
      <span class="eyebrow-dot" aria-hidden="true"></span>
      <span class="eyebrow-pill eyebrow-pill--amber" aria-label="Active illness">
        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
        </svg>
      </span>
    <% end %>
    <div class="eyebrow-rule" aria-hidden="true"></div>
  </div>
  <div class="page-header-main">
    <div class="page-header-left">
      <div class="page-header-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </div>
      <div>
        <h1><%= Date.current.strftime("%A, %-d %B %Y") %></h1>
        <p class="page-header-subtitle">Your health at a glance</p>
      </div>
    </div>
    <div class="page-header-actions">
      <%= link_to appointment_summary_path, class: "btn-secondary btn-secondary--sm" do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        GP Summary
      <% end %>
    </div>
  </div>
</div>

<div class="dashboard"
     data-controller="day-reset"
     data-day-reset-date-value="<%= Date.current %>">

  <%# Declare early so all sections below can use it %>
  <% no_data = @recent_readings.none? && @recent_symptoms.none? %>

  <%# ── No data — welcome empty state ─────────────────────────────── %>
  <% if no_data %>
    <div class="section-card empty-state">
      <div class="empty-state-icon" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
          <path d="M3 12h4l3-9 4 18 3-9h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3>Welcome to Asthma Buddy</h3>
      <p>Start by logging a reading or a symptom — your dashboard fills in as you go.</p>
    </div>
  <% end %>

  <%# ── Active illness banner ────────────────────────────────────── %>
  <% if @active_illness %>
    <div class="dash-illness-banner" role="status">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
      </svg>
      <span class="dash-illness-banner-text">Active illness &middot; since <%= @active_illness[:recorded_at].strftime("%-d %b") %></span>
      <%= link_to "View &rarr;".html_safe, health_event_path(@active_illness[:id]), class: "dash-illness-banner-link" %>
    </div>
  <% end %>

  <%# ── GINA reliever threshold warning ────────────────────────── %>
  <% if @week_reliever_doses && @week_reliever_doses > 2 %>
    <div class="dash-gina-warning" role="alert">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <div class="dash-gina-warning-body">
        <strong>Reliever used <%= @week_reliever_doses %> times this week</strong>
        <p>Using your reliever more than twice a week may indicate your asthma isn't fully controlled. Worth discussing with your GP.</p>
      </div>
      <%= link_to "View usage \u2192", reliever_usage_path, class: "dash-gina-warning-link" %>
    </div>
  <% end %>

  <%# ── Personal best missing — callout ────────────────────────── %>
  <% if @personal_best.nil? && @last_reading %>
    <div class="dash-pb-banner" role="alert">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p>No personal best set — zone classifications won't show until you <%= link_to "set your personal best", profile_path %>.</p>
    </div>
  <% end %>

  <%# ── Status hero ─────────────────────────────────────────────── %>
  <% if @last_reading %>
    <% zone = @last_reading.zone || "none" %>
    <section class="dash-status dash-status--<%= zone %>" aria-label="Current status">
      <div class="dash-status-left">
        <p class="dash-status-label">Last reading</p>
        <div class="dash-status-reading">
          <span class="dash-status-value"><%= @last_reading.value %></span>
          <span class="dash-status-unit">L/min</span>
          <% if @last_reading.time_of_day.present? %>
            <span class="tod-badge tod-badge--<%= @last_reading.time_of_day %>"><%= @last_reading.time_of_day_label %></span>
          <% end %>
        </div>
        <% if @last_reading.zone && @personal_best %>
          <span class="dash-status-zone-pill">
            <%= zone.capitalize %> zone &bull; <%= @last_reading.zone_percentage %>% of best
          </span>
        <% elsif @personal_best.nil? %>
          <p class="dash-status-zone-hint">
            <%= link_to "Set your personal best", profile_path %> to see zone.
          </p>
        <% end %>
      </div>
      <p class="dash-status-ago">
        <time datetime="<%= @last_reading.recorded_at.iso8601 %>">
          <%= time_ago_in_words(@last_reading.recorded_at) %> ago
        </time>
      </p>
    </section>
  <% else %>
    <section class="dash-status dash-status--empty" aria-label="No readings yet">
      <p class="dash-status-empty-heading">No peak flow readings yet</p>
      <p class="dash-status-empty-sub">Log your first reading to start tracking your zones.</p>
    </section>
  <% end %>

  <%# ── Today's Doses ───────────────────────────────────────────── %>
  <% if @preventer_adherence.any? || @reliever_medications.any? %>
    <% sick_day_active = @active_illness && (
         @preventer_adherence.any? { |e| e[:sick_day_dose_puffs].present? } ||
         @reliever_medications.any? { |m| m[:sick_day_dose_puffs].present? }
       ) %>
    <section class="dash-adherence" aria-label="Today's doses">
      <div class="dash-section-header">
        <div class="dash-section-header-left">
          <h2>Today's Doses</h2>
          <% if sick_day_active %>
            <span class="dash-sick-day-tag">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
              </svg>
              Sick day doses
            </span>
          <% end %>
        </div>
        <div class="dash-section-links">
          <%= link_to "Preventer History", preventer_history_path, class: "dash-section-link" %>
          <%= link_to "Reliever Usage", reliever_usage_path, class: "dash-section-link" %>
        </div>
      </div>
      <%= render "dashboard/today_doses_list",
            preventer_adherence: @preventer_adherence,
            reliever_medications: @reliever_medications,
            active_illness: @active_illness %>
    </section>
  <% end %>

  <%# ── Primary CTAs ────────────────────────────────────────────── %>
  <div class="dash-quick-log" aria-label="Quick log actions">
    <%= link_to new_peak_flow_reading_path, class: "dash-quick-btn dash-quick-btn--pf" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
      <span>Log peak flow</span>
    <% end %>
    <%= link_to new_symptom_log_path, class: "dash-quick-btn dash-quick-btn--sym" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
        <rect x="9" y="3" width="6" height="4" rx="1"/>
        <line x1="9" y1="12" x2="15" y2="12"/>
        <line x1="9" y1="16" x2="13" y2="16"/>
      </svg>
      <span>Log symptom</span>
    <% end %>
  </div>

  <%# ── This Week — summary stats + chart ───────────────────────── %>
  <% unless no_data %>
    <section class="dash-week-section" aria-label="This week's data">
      <div class="dash-section-header">
        <h2>This Week</h2>
        <div class="dash-section-links">
          <%= link_to "Peak Flow", peak_flow_readings_path(anchor: "peak-flow-graph"), class: "dash-section-link" %>
          <%= link_to "Symptoms", symptom_logs_path(anchor: "symptoms-graph"), class: "dash-section-link" %>
        </div>
      </div>

      <% if @week_interpretation %>
        <div class="dash-insight-card dash-insight-card--<%= @week_avg_zone || "none" %>" role="status">
          <div class="dash-insight-icon" aria-hidden="true">
            <% if @week_avg_zone == "green" %>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <% elsif @week_avg_zone == "yellow" %>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <% elsif @week_avg_zone == "red" %>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <% else %>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <% end %>
          </div>
          <p class="dash-insight-text"><%= @week_interpretation %></p>
        </div>
      <% end %>

      <%# Summary stats row — readings count, average, symptom count %>
      <div class="dash-stats">
        <div class="dash-stat">
          <span class="dash-stat-label">Readings</span>
          <% if @week_reading_count > 0 %>
            <span class="dash-stat-value"><%= @week_reading_count %></span>
          <% else %>
            <span class="dash-stat-value dash-stat-value--empty">&mdash;</span>
          <% end %>
        </div>
        <div class="dash-stat">
          <span class="dash-stat-label">Avg this week</span>
          <% if @week_avg %>
            <span class="dash-stat-value dash-stat-value--zone-<%= @week_avg_zone || "none" %>"><%= @week_avg %><span class="dash-stat-unit"> L/min</span></span>
          <% else %>
            <span class="dash-stat-value dash-stat-value--empty">&mdash;</span>
          <% end %>
        </div>
        <div class="dash-stat">
          <span class="dash-stat-label">Symptoms</span>
          <% if @week_symptom_count > 0 %>
            <span class="dash-stat-value dash-stat-value--severe"><%= @week_symptom_count %></span>
          <% else %>
            <span class="dash-stat-value dash-stat-value--ok">None</span>
          <% end %>
        </div>
      </div>

      <%# Symptom severity breakdown — only shown when there are symptoms this week %>
      <% if @week_symptom_count > 0 %>
      <div class="dash-severity-cards">
        <div class="dash-severity-card dash-severity-card--mild">
          <span class="dash-severity-count"><%= @week_severity_counts[:mild] %></span>
          <span class="dash-severity-label">mild</span>
        </div>
        <div class="dash-severity-card dash-severity-card--moderate">
          <span class="dash-severity-count"><%= @week_severity_counts[:moderate] %></span>
          <span class="dash-severity-label">moderate</span>
        </div>
        <div class="dash-severity-card dash-severity-card--severe">
          <span class="dash-severity-count"><%= @week_severity_counts[:severe] %></span>
          <span class="dash-severity-label">severe</span>
        </div>
      </div>
      <% end %>

      <%# Peak flow chart %>
      <% if @chart_data.any? %>
        <hr class="dash-divider">
        <div class="chart-section"
             data-controller="chart"
             data-chart-type-value="peakflow-bands"
             data-chart-data-value="<%= @chart_data.to_json %>"
             data-chart-personal-best-value="<%= @personal_best&.value || 0 %>"
             data-chart-health-events-value="<%= @health_event_markers.to_json %>">
          <div class="chart-session-toggle" role="group" aria-label="Toggle session">
            <button type="button"
                    class="chart-session-btn chart-session-btn--morning"
                    data-chart-target="sessionBtn"
                    data-chart-series-param="morning"
                    data-action="click->chart#toggleSeries"
                    aria-pressed="true">
              <span class="chart-session-btn-dot" aria-hidden="true"></span>
              Morning
            </button>
            <button type="button"
                    class="chart-session-btn chart-session-btn--evening"
                    data-chart-target="sessionBtn"
                    data-chart-series-param="evening"
                    data-action="click->chart#toggleSeries"
                    aria-pressed="true">
              <span class="chart-session-btn-dot" aria-hidden="true"></span>
              Evening
            </button>
          </div>
          <div class="chart-canvas-wrapper">
            <canvas class="chart-canvas"
                    aria-label="Peak flow readings over the last 7 days"
                    role="img">
            </canvas>
          </div>
        </div>

        <% if @personal_best %>
          <div class="dash-zone-legend" aria-label="Zone legend">
            <span class="dash-zone-legend-item dash-zone-legend-item--green">Green (&ge;80%)</span>
            <span class="dash-zone-legend-item dash-zone-legend-item--yellow">Yellow (&ge;50%)</span>
            <span class="dash-zone-legend-item dash-zone-legend-item--red">Red (&lt;50%)</span>
          </div>
        <% end %>
      <% end %>

    </section>
  <% end %>

  <%# ── Low-stock medications ───────────────────────────────────── %>
  <% if @low_stock_medications.any? %>
    <section class="dash-medications" aria-label="Low stock medications">
      <div class="dash-section-header">
        <h2>Medications</h2>
        <%= link_to "Manage", settings_medications_path(anchor: "medications-page-header"), class: "dash-section-link" %>
      </div>
      <ul class="dash-low-stock-list">
        <% @low_stock_medications.each do |medication| %>
          <li class="dash-low-stock-item">
            <span class="low-stock-badge">Low stock</span>
            <%= link_to medication.name,
                  settings_medications_path(anchor: dom_id(medication)),
                  class: "dash-low-stock-name" %>
            <span class="dash-low-stock-supply">~<%= medication.days_of_supply_remaining.round %> days left<% if medication.sick_days_of_supply_remaining.present? %> (~<%= medication.sick_days_of_supply_remaining.round %> if ill)<% end %></span>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <%# ── Recent activity ──────────────────────────────────────────── %>
  <% unless no_data %>
    <div class="dash-recents">

      <section class="dash-recent-col" aria-label="Recent peak flow readings">
        <div class="dash-section-header">
          <h2>Peak Flow</h2>
          <%= link_to "View all", peak_flow_readings_path, class: "dash-section-link" %>
        </div>
        <% if @recent_readings.any? %>
          <ul class="dash-pf-days">
            <% @recent_readings.each do |date, readings| %>
              <% morning = readings.select(&:morning?).max_by(&:value) %>
              <% evening = readings.select(&:evening?).max_by(&:value) %>
              <li class="dash-pf-day">
                <time class="dash-pf-date" datetime="<%= date.iso8601 %>">
                  <%= date.strftime("%-d %b") %>
                </time>
                <div class="dash-pf-chips">
                  <% [morning, evening].compact.each do |reading| %>
                    <%= link_to peak_flow_reading_path(reading),
                          class: "dash-pf-chip dash-pf-chip--#{reading.zone_css_modifier}",
                          aria: { label: "#{reading.time_of_day_label} reading: #{reading.value} L/min#{", #{reading.zone.capitalize} zone" if reading.zone}" } do %>
                      <span class="dash-pf-chip-session" aria-hidden="true"><%= reading.time_of_day_label %></span>
                      <span class="dash-pf-chip-value"><%= reading.value %></span>
                      <span class="dash-pf-chip-unit" aria-hidden="true">L/min</span>
                    <% end %>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
          <% if @total_reading_count > 9 %>
            <div class="dash-section-more">
              <%= link_to "View all #{@total_reading_count} readings", peak_flow_readings_path %>
            </div>
          <% end %>
        <% else %>
          <p class="dash-recent-empty">No readings yet. <%= link_to "Log one now", new_peak_flow_reading_path %>.</p>
        <% end %>
      </section>

      <section class="dash-recent-col" aria-label="Recent symptoms">
        <div class="dash-section-header">
          <h2>Symptoms</h2>
          <%= link_to "View all", symptom_logs_path, class: "dash-section-link" %>
        </div>
        <% if @recent_symptoms.any? %>
          <div class="dash-recent-list">
            <% @recent_symptoms.each do |log| %>
              <%= link_to symptom_log_path(log),
                    class: "dash-recent-row dash-recent-row--#{log.severity}",
                    aria: { label: "#{log.symptom_type.humanize}, #{log.severity}, #{log.recorded_at.strftime("%-d %b")}" } do %>
                <span class="dash-recent-symptom-type"><%= log.symptom_type.humanize %></span>
                <span class="severity-badge severity-badge--<%= log.severity %>"><%= log.severity.capitalize %></span>
                <time class="dash-recent-time" datetime="<%= log.recorded_at.iso8601 %>">
                  <%= log.recorded_at.strftime("%-d %b") %>
                </time>
              <% end %>
            <% end %>
          </div>
          <% if @total_symptom_count > 4 %>
            <div class="dash-section-more">
              <%= link_to "View all #{@total_symptom_count} symptoms", symptom_logs_path %>
            </div>
          <% end %>
        <% else %>
          <p class="dash-recent-empty">No symptoms logged. <%= link_to "Log one now", new_symptom_log_path %>.</p>
        <% end %>
      </section>

    </div>

  <% end %>

  <%# ── Medical history — outside no_data so it shows even without readings/symptoms ── %>
  <% if @recent_health_events.any? %>
    <section class="dash-health-events" aria-label="Recent medical history">
      <div class="dash-section-header">
        <h2>Medical History</h2>
        <%= link_to "View all", health_events_path, class: "dash-section-link" %>
      </div>
      <div class="dash-health-events-list">
        <% @recent_health_events.each do |event| %>
          <%= link_to health_event_path(event),
                class: "dash-health-event-row",
                aria: { label: "#{event.event_type_label}, #{event.recorded_at.strftime("%-d %b %Y")}" } do %>
            <span class="event-badge event-badge--<%= event.event_type_css_modifier %>">
              <%= event.event_type_label %>
            </span>
            <% if event.ongoing? %>
              <span class="event-ongoing-badge">Ongoing</span>
            <% end %>
            <time class="dash-health-event-time" datetime="<%= event.recorded_at.iso8601 %>">
              <%= event.recorded_at.strftime("%-d %b %Y") %>
            </time>
          <% end %>
        <% end %>
      </div>
      <% if @total_health_event_count > 3 %>
        <div class="dash-section-more">
          <%= link_to "View all #{@total_health_event_count} events", health_events_path %>
        </div>
      <% end %>
    </section>
  <% end %>


</div>
