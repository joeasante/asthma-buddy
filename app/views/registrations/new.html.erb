<% content_for :title, "Sign up" %>

<% if @user.errors.any? %>
  <div role="alert" class="flash flash--alert">
    <ul>
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<h1>Sign up</h1>

<%= form_with model: @user, url: registration_path do |form| %>
  <div>
    <%= form.label :email_address, "Email address" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email" %>
  </div>

  <div>
    <%= form.label :password, "Password" %>
    <%= form.password_field :password, required: true, autocomplete: "new-password" %>
  </div>

  <div>
    <%= form.label :password_confirmation, "Confirm password" %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
  </div>

  <%= form.submit "Sign up" %>
<% end %>

<p><%= link_to "Already have an account? Sign in", new_session_path %></p>
