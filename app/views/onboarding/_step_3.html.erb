<div class="onboarding-step-header">
  <h1>What would you like to log first?</h1>
  <p>You can log symptoms, record a peak flow reading, or do both &mdash; any time, any order.</p>
</div>

<div class="onboarding-options">
  <%= link_to symptom_logs_path, class: "section-card section-card--option" do %>
    <div class="onboarding-option-icon" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
        <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h2>Log a symptom</h2>
    <p>Record shortness of breath, wheezing, or chest tightness — with severity and notes.</p>
  <% end %>

  <%= link_to new_peak_flow_reading_path, class: "section-card section-card--option" do %>
    <div class="onboarding-option-icon" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
        <path d="M3 12h4l3-9 4 18 3-9h4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h2>Record peak flow</h2>
    <p>Take a reading with your peak flow meter and see which zone you're in.</p>
  <% end %>
</div>

<div class="onboarding-nav">
  <%= link_to "\u2190 Back", onboarding_step_path(2) %>
  <%= link_to "Skip for now", onboarding_skip_path(3), class: "btn-cancel" %>
</div>
