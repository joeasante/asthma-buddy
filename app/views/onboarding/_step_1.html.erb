<div class="section-card">
  <div class="onboarding-step-header">
    <div class="onboarding-step-icon" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
        <path d="M3 12h4l3-9 4 18 3-9h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h1>What's your personal best?</h1>
    <p>Your highest peak flow reading when feeling well. We use it to calculate your green, yellow, and red zones.</p>
  </div>

  <%= form_with url: onboarding_submit_1_path do |form| %>
    <div class="field">
      <%= form.label :value, "Personal best (L/min)" %>
      <%= form.number_field :value,
            name: "personal_best_record[value]",
            min: 100,
            max: 900,
            step: 1,
            placeholder: "e.g. 450",
            required: true,
            autofocus: true %>
    </div>

    <%= form.submit "Save and continue" %>
  <% end %>
</div>

<div class="onboarding-skip">
  <%= link_to "Skip this step", onboarding_skip_path(1), class: "btn-cancel" %>
</div>
